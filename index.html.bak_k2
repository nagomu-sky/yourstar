<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>365日の星 - あなたの誕生日に輝く星</title>
<style>
:root {
  --bg: #050714; --card: rgba(20, 22, 50, 0.6);
  --accent: #b3a5ff; --accent2: #f3d27a;
  --text: #e8e8ff; --dim: #8a8caa;
  --line: rgba(180, 180, 220, 0.15);
  --spring: #a8d8a8; --summer: #f3d27a;
  --autumn: #f3a87a; --winter: #a8c8f3;
  --stone: #c4a8ff; --love: #ff9bbe; --observe: #7ad3e8;
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; height: 100%; }
body {
  background: var(--bg); color: var(--text);
  font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
  min-height: 100vh; display: flex; align-items: flex-start; justify-content: center;
  padding: 2.5rem 1rem 3rem; overflow-x: hidden; position: relative;
}
.stars-bg {
  position: fixed; inset: 0; pointer-events: none; z-index: 0;
  background-image:
    radial-gradient(1px 1px at 20% 30%, #fff, transparent 50%),
    radial-gradient(1px 1px at 80% 10%, #fff, transparent 50%),
    radial-gradient(1.5px 1.5px at 50% 70%, #fff, transparent 50%),
    radial-gradient(1px 1px at 90% 80%, #ffd, transparent 50%),
    radial-gradient(1px 1px at 30% 90%, #fff, transparent 50%),
    radial-gradient(1px 1px at 70% 50%, #ffd, transparent 50%),
    radial-gradient(2px 2px at 10% 60%, #fff, transparent 50%);
  background-size: 1200px 800px; animation: drift 200s linear infinite; opacity: 0.7;
}
@keyframes drift { 0% { transform: translate(0, 0); } 100% { transform: translate(-100px, -50px); } }
.container { position: relative; z-index: 1; max-width: 620px; width: 100%; text-align: center; }
h1 {
  font-weight: 200; letter-spacing: 0.4em; font-size: 1.7rem; margin: 0 0 0.4rem;
  background: linear-gradient(135deg, #fff 0%, #b3a5ff 50%, #f3d27a 100%);
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
}
.subtitle { color: var(--dim); margin-bottom: 0.5rem; font-size: 0.95rem; letter-spacing: 0.1em; }
.tabs { display: flex; justify-content: center; gap: 1rem; margin-bottom: 2rem; }
.tab { background: rgba(20, 22, 50, 0.5); color: var(--dim); border: 1px solid var(--line); padding: 0.75rem 1.8rem; border-radius: 30px; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.15em; font-family: inherit; transition: all 0.3s; min-width: 140px; }
.tab.active { background: rgba(179, 165, 255, 0.15); color: var(--accent); border-color: var(--accent); }
.input-group { display: flex; flex-direction: column; gap: 0.6rem; align-items: center; margin-bottom: 1rem; }
.input-row { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
.input-block { display: flex; flex-direction: column; align-items: center; gap: 0.4rem; }
.input-label { color: var(--dim); font-size: 0.8rem; letter-spacing: 0.15em; }
input[type="date"] { background: rgba(20, 22, 50, 0.8); color: var(--text); border: 1px solid var(--line); padding: 0.8rem 1.2rem; font-size: 1rem; border-radius: 12px; color-scheme: dark; text-align: center; font-family: inherit; min-width: 180px; }
input[type="date"]:focus { outline: none; border-color: var(--accent); }
button.go { background: linear-gradient(135deg, var(--accent) 0%, #7d6dd8 100%); color: #0a0a1a; border: none; padding: 0.95rem 3rem; font-size: 1rem; border-radius: 30px; cursor: pointer; letter-spacing: 0.25em; font-weight: 600; transition: transform 0.2s, box-shadow 0.3s; font-family: inherit; min-width: 220px; }
button.go:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(179, 165, 255, 0.4); }
.result { background: var(--card); backdrop-filter: blur(10px); border: 1px solid var(--line); border-radius: 20px; padding: 2rem 1.5rem; margin-top: 1.5rem; opacity: 0; transform: translateY(20px); transition: all 0.8s ease; }
.result.show { opacity: 1; transform: translateY(0); }
.result.spring { border-color: rgba(168, 216, 168, 0.3); }
.result.summer { border-color: rgba(243, 210, 122, 0.3); }
.result.autumn { border-color: rgba(243, 168, 122, 0.3); }
.result.winter { border-color: rgba(168, 200, 243, 0.3); }
.symbol { font-size: 2.2rem; color: var(--accent2); text-align: center; margin-bottom: 0.6rem; }
.season-tag { display: inline-block; padding: 0.2rem 0.8rem; border-radius: 20px; font-size: 0.7rem; letter-spacing: 0.2em; margin-bottom: 0.8rem; }
.season-tag.spring { background: rgba(168, 216, 168, 0.2); color: var(--spring); }
.season-tag.summer { background: rgba(243, 210, 122, 0.2); color: var(--summer); }
.season-tag.autumn { background: rgba(243, 168, 122, 0.2); color: var(--autumn); }
.season-tag.winter { background: rgba(168, 200, 243, 0.2); color: var(--winter); }
.center { text-align: center; }
.date-display { color: var(--dim); font-size: 0.8rem; letter-spacing: 0.15em; margin-bottom: 1rem; }
.star-name { font-size: 1.4rem; color: var(--accent2); margin-bottom: 0; letter-spacing: 0.05em; }
.star-en { color: var(--dim); font-size: 0.8rem; margin-bottom: 0.3rem; font-style: italic; }
.const { color: var(--dim); font-size: 0.85rem; letter-spacing: 0.15em; margin-bottom: 0.5rem; }
.word { font-size: 1.3rem; font-weight: 300; color: white; line-height: 1.5; margin-bottom: 1rem; letter-spacing: 0.05em; }
.msg { color: var(--text); line-height: 1.9; font-size: 0.92rem; padding: 1rem 0; white-space: pre-line; }
.divider-line { height: 1px; background: var(--line); margin: 1rem 0; }
.observe-section { padding: 1rem 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
.observe-item { background: rgba(122, 211, 232, 0.08); border: 1px solid rgba(122, 211, 232, 0.2); border-radius: 12px; padding: 0.8rem; text-align: center; }
.observe-label { font-size: 0.7rem; letter-spacing: 0.2em; color: var(--observe); margin-bottom: 0.3rem; }
.observe-value { font-size: 0.9rem; color: white; }
.brightness-section { padding: 1rem; margin-top: 0.8rem; background: rgba(243, 210, 122, 0.06); border: 1px solid rgba(243, 210, 122, 0.2); border-radius: 12px; text-align: center; }
.brightness-mag { font-size: 1rem; color: var(--accent2); letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600; }
.brightness-msg { color: var(--text); font-size: 0.85rem; line-height: 1.7; opacity: 0.95; }
.wamei-section { padding: 1rem; margin-top: 0.8rem; background: rgba(255, 200, 220, 0.06); border: 1px solid rgba(255, 200, 220, 0.2); border-radius: 12px; text-align: center; }
.wamei-label { display: inline-block; font-size: 0.7rem; letter-spacing: 0.3em; color: #ffb8d0; background: rgba(255, 184, 208, 0.1); padding: 0.2rem 0.8rem; border-radius: 12px; margin-bottom: 0.5rem; }
.wamei-name { font-size: 1.2rem; color: #ffb8d0; margin-bottom: 0.5rem; letter-spacing: 0.1em; }
.wamei-msg { color: var(--text); font-size: 0.85rem; line-height: 1.7; opacity: 0.9; }
.stone-section { padding-top: 0.5rem; }
.stone-label { display: inline-block; font-size: 0.7rem; letter-spacing: 0.3em; color: var(--stone); background: rgba(196, 168, 255, 0.1); padding: 0.2rem 0.8rem; border-radius: 12px; margin-bottom: 0.8rem; }
.stone-name { font-size: 1.1rem; color: var(--stone); margin-bottom: 0.5rem; letter-spacing: 0.05em; }
.stone-msg { color: var(--text); line-height: 1.7; font-size: 0.85rem; opacity: 0.9; }
.compat-row { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem; align-items: center; margin-bottom: 2rem; }
.compat-mini { text-align: center; }
.compat-mini .star-name { font-size: 1.1rem; }
.compat-mini .const { font-size: 0.75rem; margin-bottom: 0.5rem; }
.compat-mini .word { font-size: 0.9rem; margin-bottom: 0; }
.compat-link { color: var(--love); font-size: 1.5rem; }
.compat-score-section { text-align: center; padding: 1.5rem 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); margin-bottom: 1.5rem; }
.compat-score { font-size: 3rem; font-weight: 300; color: var(--love); letter-spacing: 0.05em; margin-bottom: 0.3rem; }
.compat-label { font-size: 1.1rem; color: white; letter-spacing: 0.15em; margin-bottom: 0.5rem; }
.compat-tag { display: inline-block; font-size: 0.7rem; color: var(--dim); letter-spacing: 0.2em; }
.compat-msg { color: var(--text); line-height: 1.9; font-size: 0.95rem; padding: 0.5rem 0 1rem; white-space: pre-line; text-align: center; }
.stones-pair { display: flex; justify-content: center; gap: 1rem; align-items: center; color: var(--stone); font-size: 0.95rem; margin: 1rem 0 0.5rem; }
.stones-pair-msg { color: var(--text); font-size: 0.85rem; opacity: 0.9; line-height: 1.7; text-align: center; }

.share-btn { margin-top: 1.5rem; padding: 0.5rem 1.2rem; font-size: 0.85rem; background: transparent; color: var(--accent); border: 1px solid var(--accent); border-radius: 20px; cursor: pointer; font-family: inherit; }
.share-btn:hover { background: var(--accent); color: var(--bg); }

.axes-section { margin: 1rem 0; padding: 0.5rem 0; }
.axis-row { display: grid; grid-template-columns: 60px 1fr; gap: 0.8rem; align-items: center; padding: 0.5rem 0.3rem; border-bottom: 1px solid var(--line); font-size: 0.85rem; }
.axis-row:last-child { border-bottom: none; }
.axis-label { color: var(--love); letter-spacing: 0.15em; font-size: 0.75rem; text-align: right; }
.axis-msg { color: var(--text); line-height: 1.6; opacity: 0.95; }

.axes-section { margin: 1rem 0; padding: 0.5rem 0; }
.axis-row { display: grid; grid-template-columns: 60px 1fr; gap: 0.8rem; align-items: center; padding: 0.5rem 0.3rem; border-bottom: 1px solid var(--line); font-size: 0.85rem; }
.axis-row:last-child { border-bottom: none; }
.axis-label { color: var(--love); letter-spacing: 0.15em; font-size: 0.75rem; text-align: right; }
.axis-msg { color: var(--text); line-height: 1.6; opacity: 0.95; }

.compat-character { padding: 1.6rem 1rem; margin: 1rem 0 1.5rem; border: 1px solid; border-radius: 16px; background: rgba(20, 22, 50, 0.4); text-align: center; }
.compat-phrase { font-size: 1.4rem; font-weight: 300; letter-spacing: 0.08em; line-height: 1.6; margin-bottom: 0.6rem; }
.compat-sub { color: var(--text); font-size: 0.95rem; line-height: 1.7; opacity: 0.9; letter-spacing: 0.05em; }
.compat-aspect-line { margin-top: 0.6rem; font-size: 0.75rem; color: var(--dim); letter-spacing: 0.15em; }
.compat-aspect-name { color: var(--accent); font-weight: 500; margin-left: 0.4em; }
.compat-score-line { display: flex; align-items: baseline; justify-content: center; gap: 0.5em; margin-top: 1rem; padding-top: 0.8rem; border-top: 1px solid var(--line); }
.compat-score-label { font-size: 0.78rem; color: var(--dim); letter-spacing: 0.2em; }
.compat-score-num { font-size: 1.8rem; font-weight: 300; letter-spacing: 0.05em; }
.compat-score-max { font-size: 0.8rem; color: var(--dim); }

.again-btn { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 1.5rem; padding: 0.6rem 1.5rem; background: transparent; color: var(--dim); border: 1px solid var(--line); border-radius: 20px; cursor: pointer; font-family: inherit; font-size: 0.85rem; letter-spacing: 0.1em; transition: all 0.3s; }
.again-btn:hover { background: rgba(179, 165, 255, 0.1); color: var(--accent); border-color: var(--accent); }
.action-row { display: flex; justify-content: center; gap: 0.8rem; flex-wrap: wrap; margin-top: 1rem; }

.intro-card { max-width: 480px; margin: 0.5rem auto 1.2rem; padding: 1.4rem 1.5rem; background: rgba(20, 22, 50, 0.5); border: 1px solid var(--line); border-radius: 16px; text-align: center; transition: all 0.5s ease; }
.intro-card.hidden { opacity: 0; transform: translateY(-10px); height: 0; padding: 0; margin: 0; border: none; overflow: hidden; }
.intro-text { color: var(--text); font-size: 0.95rem; line-height: 2.1; letter-spacing: 0.06em; opacity: 0.9; }
.intro-accent { color: var(--accent2); font-weight: 500; }

.loading-state { padding: 3rem 1rem; text-align: center; }
.loading-pulse { font-size: 1.8rem; color: var(--accent2); animation: pulse 1.2s ease-in-out infinite; margin-bottom: 0.8rem; }
.loading-text { color: var(--dim); font-size: 0.9rem; letter-spacing: 0.1em; line-height: 1.6; opacity: 0.85; }
@keyframes pulse { 0%,100% { opacity: 0.3; transform: scale(0.9); } 50% { opacity: 1; transform: scale(1.1); } }

.footer { color: var(--dim); font-size: 0.75rem; margin-top: 2rem; letter-spacing: 0.1em; line-height: 1.8; text-align: center; }
.footer-title { color: var(--accent); font-size: 0.85rem; letter-spacing: 0.3em; margin-bottom: 0.4rem; }
.footer-tagline { color: var(--accent2); font-size: 0.9rem; letter-spacing: 0.15em; margin-bottom: 0.3rem; font-style: italic; }
.footer-sub { color: var(--dim); font-size: 0.7rem; letter-spacing: 0.15em; opacity: 0.7; }

.result { position: relative; }
.top-back-btn { position: absolute; top: 1rem; left: 1rem; background: rgba(20, 22, 50, 0.8); color: var(--dim); border: 1px solid var(--line); border-radius: 50%; width: 36px; height: 36px; cursor: pointer; font-size: 1.2rem; font-family: inherit; display: flex; align-items: center; justify-content: center; transition: all 0.3s; padding: 0; line-height: 1; }
.top-back-btn:hover { background: rgba(179, 165, 255, 0.15); color: var(--accent); border-color: var(--accent); transform: translateX(-2px); }

.observe-sub { color: var(--dim); font-size: 0.68rem; margin-top: 0.35rem; line-height: 1.5; opacity: 0.75; letter-spacing: 0.05em; }

.go-top { display: block; margin: 1.5rem auto 2rem; }
.tabs-bottom { margin-top: 0.5rem; margin-bottom: 2rem; }

.lead { color: var(--accent2); font-size: 0.95rem; letter-spacing: 0.12em; margin: 0.8rem 0 0.5rem; line-height: 1.8; opacity: 0.92; font-weight: 300; }

.result-top-btn { display: block; margin: 0 auto 1.5rem; }

.home-section { transition: opacity 0.4s ease; }
.home-section.hidden { display: none; }

.result-intro-main { color: var(--accent2); font-size: 1.15rem; letter-spacing: 0.25em; line-height: 1.8; margin: 1.2rem 0 0.3rem; font-weight: 300; }
.result-intro-sub { color: var(--dim); font-size: 0.75rem; letter-spacing: 0.18em; line-height: 1.8; margin-bottom: 1.5rem; opacity: 0.85; font-style: italic; }
.micro-label { color: var(--dim); font-size: 0.65rem; letter-spacing: 0.3em; opacity: 0.6; margin-top: 0.6rem; margin-bottom: 0.15rem; }

.compat-kabbalah { text-align: center; margin-top: 0.4rem; padding-bottom: 0.3rem; line-height: 1.7; }
.compat-kabbalah-keyword { font-size: 0.85rem; letter-spacing: 0.2em; font-weight: 500; }
.compat-kabbalah-desc { color: var(--text); font-size: 0.78rem; letter-spacing: 0.08em; opacity: 0.9; margin-top: 0.3rem; line-height: 1.7; }
</style>
</head>
<body>
<div class="stars-bg"></div>
<div class="container">
  <div id="home" class="home-section">
    <h1>3 6 5　日　の　星</h1>
    <div class="subtitle">あなたの星は、誰かが千年前に名付けていた</div>
    <div class="lead">誕生日を選んで、その名に会いにゆく。</div>
    <button class="go go-top" onclick="reveal()">星 を 呼 び 出 す</button>
    <div class="input-group">
      <div class="input-row" id="inputs"></div>
    </div>
    <div class="tabs tabs-bottom">
      <button class="tab active" data-mode="single" onclick="setMode('single')">あなたの星</button>
      <button class="tab" data-mode="compat" onclick="setMode('compat')">二人の相性</button>
    </div>
    <div id="intro-card" class="intro-card">
      <div class="intro-text">
        あなたが生まれた日、夜空には光があった。<br>
        誰がそれを、何と呼んできたか──<br>
        <span class="intro-accent">世界の言葉で、知ることができる。</span>
      </div>
    </div>
  </div>
  <div id="result" class="result"></div>
  <div class="footer">
    <div class="footer-title">365 Days of Stars</div>
    <div class="footer-tagline">あなたの星は、今夜も光っている</div>
    <div class="footer-sub">IAU公認366星 × 世界の語源 × あなたの一夜</div>
  </div>
</div>

<script>
// 366日 × IAU公認固有名星
const STARS_BY_DAY = [{"d":1,"n":"Wazn","c":"はと座","ra":5.8492,"dec":-35.75,"m":3.11,"s":"winter","o":"arabic","w":"重さの始まり","msg":"はと座の星、アラビア語で「重さ」。年初の冬空、新しい荷物を背負う準備をする時。","st":"ラピスラズリ","sm":"重みを抱く、夜空の深青。"},{"d":2,"n":"Betelgeuse","c":"オリオン座","ra":5.9194,"dec":7.4,"m":0.57,"s":"winter","o":"arabic","w":"燃える肩","msg":"いつ爆発するかわからない赤巨星。今この瞬間に、君の最大値で燃えろ。","st":"ガーネット","sm":"燃える肩を燃やす、ガーネットの赤。"},{"d":3,"n":"Menkalinan","c":"ぎょしゃ座","ra":5.9919,"dec":44.93,"m":1.9,"s":"winter","o":"arabic","w":"御者の肩","msg":"ぎょしゃ座、アラビア語で「手綱を持つ者の肩」。何かを御する者は、肩の力で世界を支える。","st":"イエロージェード","sm":"手綱を支える、温かな黄翡翠。"},{"d":4,"n":"Bagu","c":"ぎょしゃ座","ra":5.9919,"dec":54.28,"m":3.73,"s":"winter","o":"chinese","w":"八穀","msg":"ぎょしゃ座、中国の星宿で「八つの穀物」。蒔いた種は、年を超えて実る。","st":"ヒスイ","sm":"収穫を永遠に守る、翡翠の輝き。"},{"d":5,"n":"Mahasim","c":"ぎょしゃ座","ra":5.9953,"dec":37.2,"m":2.65,"s":"winter","o":"arabic","w":"しなやかな手首","msg":"アラビア語で『手首』を意味する古名。\nぎょしゃ座に流れ着いた、ヘルクレス座のMaasymと同じ語源の星。\n手綱をあやつるのは、腕の力ではなく、手首のしなやかさ。","st":"ロードナイト","sm":"しなやかな手首を解きほぐす、優しい桃色。"},{"d":6,"n":"Propus","c":"ふたご座","ra":6.2478,"dec":22.5,"m":3.3,"s":"winter","o":"greek","w":"前へ出る足","msg":"ふたご座、ギリシャ語で「前足」。進む方向は、踏み出した足が決める。","st":"レッドジャスパー","sm":"前進を地に結ぶ、力強い赤。"},{"d":7,"n":"Shangwei","c":"きりん座","ra":6.3141,"dec":69.32,"m":4.76,"s":"winter","o":"chinese","w":"上の衛兵","msg":"きりん座、中国の星宿で「紫宮の上衛」。見守る者は、見られている人より長く立っている。","st":"タイガーアイ","sm":"上衛兵を見据える、虎の眼。"},{"d":8,"n":"Furud","c":"おおいぬ座","ra":6.3383,"dec":-30.05,"m":3.02,"s":"winter","o":"arabic","w":"独行する者","msg":"おおいぬ座、アラビア語で「孤立した者」。ひとりで歩くことを、はぐれたと呼ばなくていい。","st":"スモーキークオーツ","sm":"孤独に静けさを宿す、煙水晶。"},{"d":9,"n":"Mirzam","c":"おおいぬ座","ra":6.3781,"dec":-17.95,"m":1.96,"s":"winter","o":"arabic","w":"先導の声","msg":"シリウスより先に空に出る、おおいぬ座の前足。自分から声を上げる役は、誰かの背中を押す。","st":"ブルーフローライト","sm":"先導の声を導く、清らかな青。"},{"d":10,"n":"Tejat","c":"ふたご座","ra":6.3825,"dec":22.5,"m":2.9,"s":"winter","o":"arabic","w":"双子の足","msg":"ふたご座、アラビア語で「双子」。ペアで在ることは、ひとりで在るより難しい。","st":"ローズクオーツ","sm":"寄り添う心に愛を宿す、ローズの輝き。"},{"d":11,"n":"Canopus","c":"りゅうこつ座","ra":6.3992,"dec":-52.68,"m":-0.63,"s":"winter","o":"greek","w":"南の極み","msg":"低い空に一瞬だけ昇る星。会えた時に、ちゃんと見上げろ。","st":"トパーズ","sm":"南の極みに確かさを宿す、金の石。"},{"d":12,"n":"Alhena","c":"ふたご座","ra":6.6283,"dec":16.38,"m":1.93,"s":"winter","o":"arabic","w":"双子の足跡","msg":"ふたご座、アラビア語で「ラクダの首の印」。君が通った場所には、君だけの跡が残る。","st":"クリアクオーツ","sm":"記憶を清浄に保つ、白の結晶。"},{"d":13,"n":"Pipit","c":"とも座","ra":6.6292,"dec":-43.18,"m":3.15,"s":"winter","o":"indonesian","w":"小鳥","msg":"とも座、ボルネオのケンダヤン族の言葉で「ピピ鳥」。小さな声でも、名を持つことは光る。","st":"ローズクオーツ","sm":"小さき声を優しく抱く、桃色の石。"},{"d":14,"n":"Mebsuta","c":"ふたご座","ra":6.7319,"dec":25.12,"m":2.99,"s":"winter","o":"arabic","w":"伸ばされた足","msg":"ふたご座、アラビア語で「獅子の伸ばされた前足」。力を伸ばす時は、思い切り伸ばせ。","st":"イエロートパーズ","sm":"伸ばされた足に陽を宿す、トパーズの輝き。"},{"d":15,"n":"Sirius","c":"おおいぬ座","ra":6.7525,"dec":-16.7,"m":-1.44,"s":"winter","o":"greek","w":"永遠の輝き","msg":"夜空でいちばん明るい星。君の存在は、知らない誰かの夜を照らす。","st":"ダイヤモンド","sm":"永遠を永遠に閉じ込める、不滅の輝き。"},{"d":16,"n":"Alzirr","c":"ふたご座","ra":6.7547,"dec":12.88,"m":3.33,"s":"winter","o":"arabic","w":"結びの一点","msg":"ふたご座、アラビア語で「ボタン」。小さな留め具が、大きな布をまとめる。","st":"クォーツ","sm":"留めるものに光を宿す、クォーツ。"},{"d":17,"n":"Adhara","c":"おおいぬ座","ra":6.9769,"dec":-28.97,"m":1.53,"s":"winter","o":"arabic","w":"処女たち","msg":"アラビア語で「処女たち」、おおいぬ座の星。自分の中の純度を守れ。","st":"ホワイトムーンストーン","sm":"純度を月光で清める、白の石。"},{"d":18,"n":"Tonglingxing","c":"きりん座","ra":7.0011,"dec":76.97,"m":4.551,"s":"winter","o":"chinese","w":"桐の御陵","msg":"きりん座、中国の星宿で「桐陵」。古い名は、誰も呼ばなくても消えない。","st":"ジェード","sm":"古き名に調和を宿す、ジェード。"},{"d":19,"n":"Nganurganity","c":"おおいぬ座","ra":7.0286,"dec":-27.93,"m":3.47,"s":"winter","o":"aboriginal","w":"砂漠のトカゲ","msg":"豪州先住民ブーロン族の言葉で『ジャッキートカゲ』。\nおおいぬ座に灯る、南半球の古い名。\n動かぬ姿の奥で、瞳だけが光っている。","st":"タイガーアイ","sm":"砂漠トカゲを見据える、虎の眼。"},{"d":20,"n":"Muliphein","c":"おおいぬ座","ra":7.0626,"dec":-15.62,"m":4.1,"s":"winter","o":"arabic","w":"論争の星","msg":"おおいぬ座、アラビア語で「論争の二つ」。\n名前の解釈で千年争われてきた。\n決着のつかない問いに付き合える人を、本物と呼ぶ。","st":"レッドジャスパー","sm":"論争に根を張る、土の赤。"},{"d":21,"n":"Mekbuda","c":"ふたご座","ra":7.0685,"dec":20.57,"m":3.93,"s":"winter","o":"arabic","w":"折られた足","msg":"ふたご座、アラビア語で「獅子の折れた前足」。畳んだ力こそ、放つ時の威力になる。","st":"スモーキークオーツ","sm":"折られた足を包む、煙色の輝き。"},{"d":22,"n":"Wezen","c":"おおいぬ座","ra":7.1397,"dec":-26.38,"m":1.84,"s":"winter","o":"arabic","w":"重さの星","msg":"アラビア語で「重さ」。軽やかな人の影には、必ず引き受けた重みがある。","st":"イエローカルサイト","sm":"重みを支える、優しい黄。"},{"d":23,"n":"Wasat","c":"ふたご座","ra":7.3353,"dec":21.97,"m":3.54,"s":"winter","o":"arabic","w":"真ん中","msg":"ふたご座、アラビア語で「中央」。双子の真ん中で輝く。\n両極端を知る者だけが、中央に居られる。","st":"クリアクオーツ","sm":"中央を映す、透明な石。"},{"d":24,"n":"Aludra","c":"おおいぬ座","ra":7.4014,"dec":-29.3,"m":2.46,"s":"winter","o":"arabic","w":"純なる者","msg":"おおいぬ座、アラビア語で「純潔」。汚されない場所を、心の中に持て。","st":"ホワイトムーンストーン","sm":"純度に月の純度を宿す、ムーンストーン。"},{"d":25,"n":"Gomeisa","c":"こいぬ座","ra":7.4525,"dec":8.28,"m":2.89,"s":"winter","o":"arabic","w":"涙ぐむ目","msg":"こいぬ座の星、アラビア語で「目の小さな曇り」。泣ける夜があるのは、心が動いている証拠だ。","st":"ローズクオーツ","sm":"涙を優しく抱く、桃色の石。"},{"d":26,"n":"Castor","c":"ふたご座","ra":7.5764,"dec":31.88,"m":1.58,"s":"winter","o":"greek","w":"馬を駆る兄","msg":"ふたご座の兄、馬術の達人。技は、地味な反復からしか生まれない。","st":"ホワイトオパール","sm":"馬を彩る、虹色の白。"},{"d":27,"n":"Procyon","c":"こいぬ座","ra":7.655,"dec":5.22,"m":0.4,"s":"winter","o":"greek","w":"先駆ける者","msg":"シリウスより先に昇る、こいぬ座の主星。タイミングを掴む者が勝つ。","st":"アンバー","sm":"先駆ける者に時を宿す、琥珀色。"},{"d":28,"n":"Pollux","c":"ふたご座","ra":7.7553,"dec":28.02,"m":1.22,"s":"winter","o":"greek","w":"不死の双子","msg":"兄弟のために不死を半分譲った神話の星。本当に強い人は、誰かのために力を使える。","st":"サンストーン","sm":"不死の双子を温める、サンストーン。"},{"d":29,"n":"Azmidi","c":"とも座","ra":7.8214,"dec":-24.85,"m":3.32,"s":"winter","o":"greek","w":"誤字の星","msg":"とも座、ギリシャ語の誤記から生まれた名。\n間違いから生まれた名前にも、千年の歴史が宿る。\n完璧でないものが、いちばん美しいことがある。","st":"ローズクオーツ","sm":"誤字を優しく抱く、桃色の石。"},{"d":30,"n":"Naos","c":"とも座","ra":8.0597,"dec":-40.0,"m":2.22,"s":"winter","o":"greek","w":"船尾の灯","msg":"アルゴ船の船尾を照らす、ギリシャ語で「船」。過ぎてきた航路を照らす灯は、次の誰かの目印になる。","st":"ブルーフローライト","sm":"後方を澄ませる、フローライトの青。"},{"d":31,"n":"Tureis","c":"とも座","ra":8.1256,"dec":-24.3,"m":2.83,"s":"winter","o":"arabic","w":"小さき盾","msg":"とも座、アラビア語で「小さな盾」。一番大切なものは、一番小さな盾で守る。","st":"レッドジャスパー","sm":"護る者を支える、大地の赤。"},{"d":32,"n":"Tarf","c":"かに座","ra":8.275,"dec":9.18,"m":3.52,"s":"winter","o":"arabic","w":"獅子の眼","msg":"かに座、アラビア語で「獅子の二つの眼」。獅子の眼は慌てない。だから、間合いを見誤らない。","st":"タイガーアイ","sm":"獅子眼に勇気を宿す、虎眼石。"},{"d":33,"n":"Avior","c":"りゅうこつ座","ra":8.375,"dec":-59.5,"m":1.95,"s":"winter","o":"english","w":"空の使者","msg":"りゅうこつ座、近代航海術のために命名された。名がない時代に、自分で名を呼びにいく。","st":"ブルートパーズ","sm":"航海者を澄ませる、青のトパーズ。"},{"d":34,"n":"Alsciaukat","c":"やまねこ座","ra":8.3806,"dec":43.18,"m":4.25,"s":"winter","o":"arabic","w":"棘","msg":"やまねこ座、アラビア語で「棘」。刺す力を持つことは、悪じゃない。君の棘は、傷つけるためでなく、守るためにある。","st":"オニキス","sm":"棘に静けさを宿す、深い黒。"},{"d":35,"n":"Tislit","c":"とも座","ra":8.4225,"dec":-11.5,"m":3.829,"s":"winter","o":"berber","w":"花嫁","msg":"とも座、北アフリカ・アマジグ語で「花嫁」。悲しみも、誰かが覚えていれば、名前になって残る。","st":"ローズクオーツ","sm":"傷ついた者を包み込む、優しいピンク。"},{"d":36,"n":"Muscida","c":"おおぐま座","ra":8.5042,"dec":60.72,"m":3.36,"s":"winter","o":"latin","w":"熊の鼻","msg":"おおぐま座、ラテン語で「鼻面」。先頭は、いちばん早く朝の風を受ける。","st":"ブルーアパタイト","sm":"先端に集中を宿す、青のアパタイト。"},{"d":37,"n":"Minchir","c":"うみへび座","ra":8.646,"dec":3.33,"m":4.48,"s":"winter","o":"arabic","w":"勇者の鼻","msg":"うみへび座、アラビア語で「勇敢な者の鼻」。\n臭覚で世界を読む者は、目より早く危険を察知する。\n感覚を研ぎ澄ますのは、知性の入り口だ。","st":"カーネリアン","sm":"嗅覚に火を灯す、温かな赤の石。"},{"d":38,"n":"Asellus Borealis","c":"かに座","ra":8.7214,"dec":21.47,"m":4.673,"s":"winter","o":"latin","w":"北のロバ","msg":"かに座、ローマ名で「北のロバ」。地味でも、確実に荷物を運ぶ者になれ。","st":"イエロージャスパー","sm":"北ロバを支える、大地の黄色。"},{"d":39,"n":"Asellus Australis","c":"かに座","ra":8.7447,"dec":18.15,"m":3.93,"s":"winter","o":"latin","w":"南のロバ","msg":"かに座、ローマ名で「南のロバ」。双子のロバは、並んで歩む。","st":"イエロージャスパー","sm":"歩みに安定を宿す、黄のジャスパー。"},{"d":40,"n":"Alsephina","c":"ほ座","ra":8.745,"dec":-54.7,"m":1.94,"s":"winter","o":"arabic","w":"近代の船","msg":"ほ座、近代の命名。名のない時代を経て、ようやく船と呼ばれるようになった。","st":"ブルーアパタイト","sm":"航海に集中を宿す、青のアパタイト。"},{"d":41,"n":"Yuyu","c":"かに座","ra":8.7783,"dec":28.75,"m":4.03,"s":"winter","o":"indonesian","w":"沢蟹","msg":"かに座、ジャワ語で「淡水蟹」。\nインドネシアの田んぼに住む小さな蟹が、星の名になった。\n足元の生き物にも、空にいる場所がある。","st":"イエロージャスパー","sm":"水田を支える、大地の黄色。"},{"d":42,"n":"Ashlesha","c":"うみへび座","ra":8.7794,"dec":6.42,"m":3.42,"s":"winter","o":"sanskrit","w":"蛇の抱擁","msg":"うみへび座、サンスクリット語の月宿名。\n蛇に抱かれることは、死を意味する。\n恐れを抱きしめる者だけが、その先を見る。","st":"エメラルド","sm":"蛇を清める、深い翠。"},{"d":43,"n":"Acubens","c":"かに座","ra":8.9748,"dec":11.85,"m":4.2,"s":"winter","o":"arabic","w":"蟹の爪","msg":"かに座、アラビア語で「爪」、プトレマイオスが用いた名。\n挟む力は、緩める時を知る者にだけ与えられる。","st":"カーネリアン","sm":"蟹爪の奥で燃える、勇気の赤。"},{"d":44,"n":"Talitha","c":"おおぐま座","ra":8.9864,"dec":48.03,"m":3.14,"s":"winter","o":"arabic","w":"三番目の跳躍","msg":"おおぐま座、アラビア語で「三番目」、ガゼルの三度目の跳ねる足跡。三度目の挑戦には、一度目とは違う知恵がある。","st":"レッドカーネリアン","sm":"跳躍に火を入れる、再生の赤。"},{"d":45,"n":"Alkaphrah","c":"おおぐま座","ra":9.0603,"dec":47.15,"m":3.58,"s":"winter","o":"arabic","w":"跳躍","msg":"おおぐま座、アラビア語で「跳ねること」、ガゼル群の名残。\nガゼルの軽やかさは、地に足を着けた瞬間に生まれる。","st":"タイガーアイ","sm":"跳躍を貫く、金の眼差し。"},{"d":46,"n":"Suhail","c":"ほ座","ra":9.1331,"dec":-43.42,"m":2.2,"s":"winter","o":"arabic","w":"英雄譚","msg":"アラブの英雄スハイルから、ほ座の星。誰かの物語の中で生きるより、自分の物語を書け。","st":"カーネリアン","sm":"自分の物語を支える、生命の赤。"},{"d":47,"n":"Miaplacidus","c":"りゅうこつ座","ra":9.22,"dec":-69.72,"m":1.67,"s":"winter","o":"latin","w":"穏やかな水","msg":"りゅうこつ座、アラビア語＋ラテン語の混成名で「静かな水面」。静止しているように見えて、深いところで流れている。","st":"アクアマリン","sm":"穏やかな水に静けさを宿す、海色の石。"},{"d":48,"n":"Aspidiske","c":"りゅうこつ座","ra":9.2847,"dec":-59.27,"m":2.25,"s":"winter","o":"greek","w":"古の小盾","msg":"りゅうこつ座、ギリシャ語で「小盾」、アルゴ船を守った装備。\n目立たない守りこそ、船をいちばん遠くまで運ぶ。","st":"ブルーアパタイト","sm":"航海の守りに集中を宿す、青のアパタイト。"},{"d":49,"n":"Markeb","c":"ほ座","ra":9.3683,"dec":-55.0,"m":2.48,"s":"winter","o":"arabic","w":"帆を運ぶ星","msg":"ほ座、アラビア語で「乗り物・船」。運ぶ者と運ばれる者の境界線。","st":"ブルーアパタイト","sm":"帆を研ぐ、鋭い青の石。"},{"d":50,"n":"Alphard","c":"うみへび座","ra":9.4597,"dec":-8.65,"m":1.98,"s":"winter","o":"arabic","w":"孤独な誇り","msg":"うみへび座にぽつんと光る、アラビア語で「孤独な者」。群れない強さは、弱さじゃない。","st":"オレンジカーネリアン","sm":"単独で立つ温かい誇りの石。"},{"d":51,"n":"Alterf","c":"しし座","ra":9.5287,"dec":22.97,"m":4.32,"s":"winter","o":"arabic","w":"獅子の眼差し","msg":"しし座、アラビア語で「目」。見ること、それが最初の力だ。","st":"タイガーアイ","sm":"獅子眼差しを貫く、金の眼差し。"},{"d":52,"n":"Ukdah","c":"うみへび座","ra":9.6642,"dec":-1.13,"m":3.89,"s":"winter","o":"arabic","w":"解けぬ結び","msg":"うみへび座、アラビア語で「結び目」、4つの星が織りなす結び目の形。\n結び目は、解くより結ぶ方が難しい。","st":"ピンクトルマリン","sm":"繋ぎに愛を運ぶ、トルマリンの桃色。"},{"d":53,"n":"Subra","c":"しし座","ra":9.6856,"dec":9.88,"m":3.51,"s":"winter","o":"arabic","w":"獅子の脇","msg":"しし座、アラビア語で「ライオンの背中」。獅子の堂々とした姿は、正面より、脇から見たときに分かる。","st":"イエロージャスパー","sm":"背中を支える、大地の黄色。"},{"d":54,"n":"Zhang","c":"うみへび座","ra":9.858,"dec":-14.83,"m":4.12,"s":"winter","o":"chinese","w":"伸ばす","msg":"うみへび座、中国の星宿で「伸びゆく」。伸びることは、空間を信じること。","st":"ジェード","sm":"伸ばすに調和を宿す、ジェード。"},{"d":55,"n":"Rasalas","c":"しし座","ra":9.8792,"dec":26.0,"m":3.88,"s":"winter","o":"arabic","w":"獅子の頭","msg":"しし座、アラビア語で「南向きの頭」。向く方向で、見える景色が変わる。","st":"タイガーアイ","sm":"向きを見据える、虎の眼。"},{"d":56,"n":"Yunü","c":"しし座","ra":10.1317,"dec":9.98,"m":4.39,"s":"winter","o":"chinese","w":"御女","msg":"しし座、中国の星宿で「侍女」。\n仕える者は、仕える相手より長く星に名を残す。\n陰の役は、光の役より深く宇宙に刻まれる。","st":"ヒスイ","sm":"侍女に古の力を宿す、ヒスイ。"},{"d":57,"n":"Regulus","c":"しし座","ra":10.1394,"dec":11.97,"m":1.41,"s":"winter","o":"latin","w":"王の心臓","msg":"獅子の胸で鼓動する春の星。リーダーの資質は、恐れずに胸を張ること。","st":"アクアマリン","sm":"王の判断を澄ませる、海の青。"},{"d":58,"n":"Adhafera","c":"しし座","ra":10.2781,"dec":23.42,"m":3.44,"s":"winter","o":"arabic","w":"巻き毛","msg":"しし座、アラビア語で「巻き毛」、本来は星雲の名。名は、誤解されながら旅を続ける。","st":"カルセドニー","sm":"名に穏やかさを宿す、カルセドニー。"},{"d":59,"n":"Tania Borealis","c":"おおぐま座","ra":10.2847,"dec":42.9,"m":3.44,"s":"winter","o":"arabic","w":"北の二番目","msg":"おおぐま座、アラビア語＋ラテン語で「北の二番目」。二番目の跳躍は、一度目より遠くまで届く。","st":"イエロージャスパー","sm":"跡を支える、大地の黄色。"},{"d":60,"n":"Algieba","c":"しし座","ra":10.3328,"dec":19.83,"m":2.23,"s":"winter","o":"arabic","w":"たてがみ","msg":"獅子のたてがみで輝く二重星。見せ場を持っていることは、ずるいことじゃない。","st":"シトリン","sm":"たてがみを満たす、太陽の黄。"},{"d":61,"n":"Tania Australis","c":"おおぐま座","ra":10.3719,"dec":41.48,"m":3.04,"s":"winter","o":"arabic","w":"南の二番目","msg":"おおぐま座、アラビア語＋ラテン語で「南の二番目」、ガゼルの跳ねた跡。同じ跳躍を、もう一度。それでこそ砂漠は渡れる。","st":"イエロージャスパー","sm":"跡を地に結ぶ、土の黄。"},{"d":62,"n":"Shaomin","c":"しし座","ra":10.5467,"dec":9.3,"m":3.82,"s":"winter","o":"chinese","w":"少民","msg":"しし座、中国の星宿で「少民」、軒轅星座の南端。\n少数派でいることは、孤独じゃない。低いところからしか見えない景色を、君は知っている。","st":"ヒスイ","sm":"少数に古の力を宿す、ヒスイ。"},{"d":63,"n":"Praecipua","c":"こじし座","ra":10.8883,"dec":34.2,"m":3.79,"s":"spring","o":"latin","w":"一番手","msg":"こじし座、ラテン語で「主たる者」。小さな場所でいちばんになる ── それも、立派ないちばんだ。","st":"クリアクオーツ","sm":"主たる者を清浄に保つ、白の結晶。"},{"d":64,"n":"Alkes","c":"コップ座","ra":10.9962,"dec":-18.28,"m":4.07,"s":"spring","o":"arabic","w":"杯","msg":"コップ座、アラビア語で「杯」、星座そのもの。空の杯にも、いつか満たされる時が来る。","st":"クリスタル","sm":"杯を清める、クリスタルの輝き。"},{"d":65,"n":"Merak","c":"おおぐま座","ra":11.0306,"dec":56.37,"m":2.35,"s":"spring","o":"arabic","w":"熊の腰","msg":"おおぐま座、アラビア語で「腰」、北斗七星の器の左下。重いものを持ち上げる力は、腕ではなく腰から出る。","st":"イエロージェード","sm":"形を支える、温かな黄翡翠。"},{"d":66,"n":"Dubhe","c":"おおぐま座","ra":11.0619,"dec":61.75,"m":1.82,"s":"spring","o":"arabic","w":"北を指す","msg":"北斗七星の先頭、北極星を見つける目印。誰かが方角を見失った時の指標になれ。","st":"サンストーン","sm":"北を指し示す、太陽の石。"},{"d":67,"n":"Zosma","c":"しし座","ra":11.235,"dec":20.52,"m":2.56,"s":"spring","o":"greek","w":"獅子の帯","msg":"しし座、ギリシャ語で「腰巻き」。上半身と下半身を繋ぐ腰は、力の起点。","st":"イエロージャスパー","sm":"腰の力を地に結ぶ、土の黄。"},{"d":68,"n":"Chertan","c":"しし座","ra":11.2372,"dec":15.42,"m":3.3,"s":"spring","o":"arabic","w":"小さき肋骨","msg":"しし座、アラビア語で『胸の小さな二本の肋骨』。\n肋骨は、いちばん大切なものを、内側からそっと囲っている。","st":"ローズクオーツ","sm":"支える肋を温める、桜色の石。"},{"d":69,"n":"Alula Australis","c":"おおぐま座","ra":11.303,"dec":31.52,"m":4.264,"s":"spring","o":"arabic","w":"南の最初の跳躍","msg":"おおぐま座、アラビア語＋ラテン語で「南の最初の跳躍」、ガゼルの足跡。\n最初の一歩は、振り返るより前に踏み出すもの。","st":"レッドカーネリアン","sm":"最初を駆動する、勇気の赤。"},{"d":70,"n":"Alula Borealis","c":"おおぐま座","ra":11.3078,"dec":33.08,"m":3.48,"s":"spring","o":"arabic","w":"北の最初の跳躍","msg":"おおぐま座、アラビア語＋ラテン語で「北の最初の跳躍」。\nガゼルは振り返らない。後ろを見るのは捕食者だ。","st":"レッドカーネリアン","sm":"跳躍に火を入れる、再生の赤。"},{"d":71,"n":"Giausar","c":"りゅう座","ra":11.5233,"dec":69.32,"m":3.81,"s":"spring","o":"persian","w":"竜の鼻先","msg":"りゅう座、アラビア語に由来。先頭に立つ者は、空気を切る音を聞いている。","st":"ブルーアパタイト","sm":"先端を研ぐ、鋭い青の石。"},{"d":72,"n":"Taiyangshou","c":"おおぐま座","ra":11.7672,"dec":47.77,"m":3.69,"s":"spring","o":"chinese","w":"陽の守護者","msg":"おおぐま座、中国名で「太陽の番人」、宰相を象徴する。\n光を守る者は、自らも光らねばならない。","st":"シトリン","sm":"陽の守護者を満たす、太陽の黄。"},{"d":73,"n":"Denebola","c":"しし座","ra":11.8175,"dec":14.57,"m":2.13,"s":"spring","o":"arabic","w":"獅子の尾","msg":"しし座の尾、アラビア語で「獅子のしっぽ」。後ろ姿でも品が出る人は本物。","st":"ホワイトクリスタル","sm":"獅子尾を清浄に保つ、白の結晶。"},{"d":74,"n":"Zavijava","c":"おとめ座","ra":11.845,"dec":1.75,"m":3.59,"s":"spring","o":"arabic","w":"犬の角","msg":"おとめ座、アラビア語に由来。似ていないものを結びつける名がある。","st":"アゲート","sm":"犬角に層を重ねる、アゲート。"},{"d":75,"n":"Phecda","c":"おおぐま座","ra":11.8969,"dec":53.68,"m":2.39,"s":"spring","o":"arabic","w":"北斗の腿","msg":"おおぐま座、アラビア語で「太腿」、北斗七星の器の右下。太腿は、地に立つ力の源。","st":"イエロージャスパー","sm":"立つ力に安定を宿す、黄のジャスパー。"},{"d":76,"n":"Alchiba","c":"からす座","ra":12.1402,"dec":-24.72,"m":4.03,"s":"spring","o":"arabic","w":"天幕","msg":"からす座、アラビア語で「天幕」。大きな空の下、自分の小さな天幕を持て。","st":"レッドジャスパー","sm":"天幕を支える、大地の赤。"},{"d":77,"n":"Imai","c":"みなみじゅうじ座","ra":12.2522,"dec":-58.73,"m":2.74,"s":"spring","o":"african","w":"洪水を告げる星","msg":"みなみじゅうじ座、ムルシ族の言葉で、四つ並ぶ星の一つ。\nオモ川の氾濫を予告する星々のひとつ。\n自然のリズムに耳を澄ます者が、長く生きる。","st":"ジェード","sm":"大地を結ぶ、緑の翡翠。"},{"d":78,"n":"Megrez","c":"おおぐま座","ra":12.2569,"dec":57.02,"m":3.3,"s":"spring","o":"arabic","w":"尾の付け根","msg":"おおぐま座、アラビア語で「尾の根」、北斗七星の柄の付け根。尾の付け根は、振られる尾と、動かない体をつなぐ。","st":"イエロージェード","sm":"根に滋養を宿す、黄のジェード。"},{"d":79,"n":"Gienah","c":"からす座","ra":12.2633,"dec":-17.53,"m":2.59,"s":"spring","o":"arabic","w":"烏の右翼","msg":"からす座、アラビア語で「翼」、烏の右翼。空を飛ぶには、左右両方の翼が要る。","st":"ブルートパーズ","sm":"翼を照らす、透き通る青。"},{"d":80,"n":"Zaniah","c":"おとめ座","ra":12.3317,"dec":-0.07,"m":3.87,"s":"spring","o":"arabic","w":"傾いた角","msg":"おとめ座、アラビア語で「角」、後に「傾いた」と読まれた。同じ言葉に、後の世が新しい意味を読み足すことがある。","st":"エメラルド","sm":"傾いた角に若さを宿す、エメラルドの輝き。"},{"d":81,"n":"Ginan","c":"みなみじゅうじ座","ra":12.3558,"dec":-60.4,"m":3.58,"s":"spring","o":"aboriginal","w":"赤いベリー","msg":"みなみじゅうじ座、豪州先住民ワダマン族の言葉。旅人の腰袋の赤い実が、星の名前になった。","st":"カーネリアン","sm":"赤いベリーに火を灯す、温かな赤の石。"},{"d":82,"n":"Acrux","c":"みなみじゅうじ座","ra":12.4431,"dec":-63.08,"m":1.28,"s":"spring","o":"contemporary","w":"南の十字","msg":"南半球の航海者の道しるべ、南十字星の主星。誰かの方角になれ。","st":"ブルーカルセドニー","sm":"航海者を穏やかに包む、淡い青。"},{"d":83,"n":"Algorab","c":"からす座","ra":12.4975,"dec":-16.5,"m":2.97,"s":"spring","o":"arabic","w":"烏の翼","msg":"からす座、アラビア語で「烏の翼」。\n黒い翼にも、夜空には欠かせない場所がある。","st":"オニキス","sm":"烏を守る、漆黒の石。"},{"d":84,"n":"Gacrux","c":"みなみじゅうじ座","ra":12.5192,"dec":-57.1,"m":1.65,"s":"spring","o":"contemporary","w":"紅葉の十字","msg":"南十字に赤く灯る星。季節は変わる。今の景色を、覚えておけ。","st":"ロードクロサイト","sm":"今に情を宿す、深い桃色。"},{"d":85,"n":"Chara","c":"りょうけん座","ra":12.5624,"dec":41.35,"m":4.25,"s":"spring","o":"greek","w":"愛しき者","msg":"りょうけん座、ギリシャ語で「喜び」。誰かに愛される存在になるには、まず自分を愛すること。","st":"ローズクオーツ","sm":"愛を優しく抱く、桃色の石。"},{"d":86,"n":"Kraz","c":"からす座","ra":12.5731,"dec":-23.38,"m":2.66,"s":"spring","o":"contemporary","w":"無名の烏","msg":"からす座、近代命名で由来不詳。名がない場所にも、誰かが名をつける。","st":"オニキス","sm":"名のない場所に静けさを宿す、深い黒。"},{"d":87,"n":"Phyllon Kissinou","c":"かみのけ座","ra":12.5809,"dec":22.62,"m":4.8,"s":"spring","o":"greek","w":"蔦の葉","msg":"かみのけ座、ギリシャ語で「蔦の葉」、プトレマイオスの記述から。\n蔦は、絡む対象を選ぶことで自分の形を作る。","st":"エメラルド","sm":"蔦を清める、深い翠。"},{"d":88,"n":"Porrima","c":"おとめ座","ra":12.6944,"dec":-1.43,"m":2.74,"s":"spring","o":"latin","w":"予言の女神","msg":"おとめ座、ローマ神話の予言女神ポルリマから。\n未来を語る者は、過去を深く知る者でもある。","st":"ムーンストーン","sm":"予言に月の力を宿す、白の輝き。"},{"d":89,"n":"Mimosa","c":"みなみじゅうじ座","ra":12.7953,"dec":-59.68,"m":1.31,"s":"spring","o":"latin","w":"紅の十字","msg":"南十字星のなかで青く輝く。似たもの同士の中でも、自分の色を残せ。","st":"ブルートパーズ","sm":"個性に清らかさを宿す、青の宝石。"},{"d":90,"n":"Alioth","c":"おおぐま座","ra":12.9003,"dec":55.95,"m":1.76,"s":"spring","o":"arabic","w":"母熊の背","msg":"北斗七星の柄の付け根。子は、母熊の背中を見て、歩き方を覚える。","st":"イエロージェード","sm":"母熊背に滋養を宿す、黄のジェード。"},{"d":91,"n":"Minelauva","c":"おとめ座","ra":12.9264,"dec":3.38,"m":3.41,"s":"spring","o":"arabic","w":"おとめの右肩","msg":"おとめ座、アラビア語に由来。位置を表す名は、その場所への愛情を含んでいる。","st":"エメラルド","sm":"位置を育む、深い緑。"},{"d":92,"n":"Cor Caroli","c":"りょうけん座","ra":12.9336,"dec":38.32,"m":2.89,"s":"spring","o":"latin","w":"チャールズの心","msg":"りょうけん座、英国王チャールズ1世を讃えて1660年命名。誰かの心臓に名づけられた星もある。","st":"ガーネット","sm":"チャールズの心を燃やす、ガーネットの赤。"},{"d":93,"n":"Vindemiatrix","c":"おとめ座","ra":13.0361,"dec":10.95,"m":2.82,"s":"spring","o":"latin","w":"葡萄摘み","msg":"おとめ座、ラテン語で「収穫する者」、葡萄が熟す時に昇る。収穫は、待っていた人にしか来ない。","st":"エメラルド","sm":"収穫を清める、深い翠。"},{"d":94,"n":"Diadem","c":"かみのけ座","ra":13.1665,"dec":17.52,"m":4.29,"s":"spring","o":"contemporary","w":"髪の冠","msg":"かみのけ座、ギリシャ語で「ヘッドバンド」。冠は、頭の上にあるから美しい。","st":"クリアクオーツ","sm":"王冠を澄ませる、清らかな水晶。"},{"d":95,"n":"Naga","c":"うみへび座","ra":13.3153,"dec":-23.17,"m":3.0,"s":"spring","o":"sanskrit","w":"大蛇","msg":"うみへび座、サンスクリット語で「大蛇」「龍」。\n蛇は脱皮して再生する。\n古い自分を捨てることは、死じゃない。","st":"エメラルド","sm":"蛇に若さを宿す、エメラルドの輝き。"},{"d":96,"n":"Kulou","c":"ケンタウルス座","ra":13.3431,"dec":-36.7,"m":2.72,"s":"spring","o":"chinese","w":"武器庫","msg":"ケンタウルス座、紀元前2世紀の中国の星宿で「兵器庫」。\n備えあれば憂いなし。\nしかし、武器庫を持つ者は、それを使わない知恵も持つ。","st":"オニキス","sm":"武器庫に静けさを宿す、深い黒。"},{"d":97,"n":"Mizar","c":"おおぐま座","ra":13.3986,"dec":54.92,"m":2.22,"s":"spring","o":"arabic","w":"双子のひとつ","msg":"アルコルとペアの星、おおぐま座の柄。見えないけれど隣にいる人を、たまに思い出せ。","st":"セレナイト","sm":"見えない隣人を繋ぐ、月の石。"},{"d":98,"n":"Spica","c":"おとめ座","ra":13.4197,"dec":-11.15,"m":1.06,"s":"spring","o":"latin","w":"麦の穂","msg":"おとめ座の豊穣の星。蒔いた種は、見えないところで根を張っている。","st":"パール","sm":"麦の穂を映す、月の真珠。"},{"d":99,"n":"Alcor","c":"おおぐま座","ra":13.4204,"dec":54.98,"m":3.99,"s":"spring","o":"arabic","w":"忘れられた者","msg":"おおぐま座、ミザルの隣の暗い星、視力の試金石。小さな光こそ、見つけた人の目を試している。","st":"ムーンストーン","sm":"忘れられたを月光で包む、神秘の石。"},{"d":100,"n":"Apamvatsa","c":"おとめ座","ra":13.5327,"dec":-6.25,"m":4.69,"s":"spring","o":"sanskrit","w":"天の子牛","msg":"おとめ座、サンスクリット語の星名。君が見上げる光は、千年前の誰かも見上げていた。","st":"エメラルド","sm":"古代を育む、深い緑。"},{"d":101,"n":"Heze","c":"おとめ座","ra":13.5781,"dec":-0.58,"m":3.38,"s":"spring","o":"latin","w":"変わらぬ位置","msg":"おとめ座、ラテン語に由来する古名。名前は変わっても、位置は変わらない。","st":"エメラルド","sm":"変わらぬ位置に若さを宿す、エメラルドの輝き。"},{"d":102,"n":"Tepiamenit","c":"うしかい座","ra":13.7877,"dec":17.45,"m":4.5,"s":"spring","o":"egyptian","w":"北の先導者","msg":"うしかい座、エジプト語で「極の先駆者」、第二千年紀の星時計に記録。\n他の人より先に到着する者は、待つ時間を持つ者。","st":"ラピスラズリ","sm":"北先導を覆う、ラピスの夜。"},{"d":103,"n":"Alkaid","c":"おおぐま座","ra":13.7922,"dec":49.3,"m":1.86,"s":"spring","o":"arabic","w":"指導者","msg":"おおぐま座、アラビア語で「指導者」、北斗七星の柄の先端。\n後ろから付いてくる者の存在を、忘れるな。","st":"タイガーアイ","sm":"指導を見据える、虎の眼。"},{"d":104,"n":"Heng","c":"ケンタウルス座","ra":13.825,"dec":-41.68,"m":3.37,"s":"spring","o":"chinese","w":"天の杖","msg":"ケンタウルス座、中国名で「測量具」と推定される。\n測ることで、世界の形が見えてくる。","st":"ジェード","sm":"測りに調和を宿す、ジェード。"},{"d":105,"n":"Muphrid","c":"うしかい座","ra":13.9114,"dec":18.38,"m":2.68,"s":"spring","o":"arabic","w":"独り立つ者","msg":"うしかい座、アラビア語で「孤立した」。単独で立てる者は、誰かと並ぶ意味も知っている。","st":"スモーキークオーツ","sm":"独立を包む、煙色の輝き。"},{"d":106,"n":"Leepwal","c":"ケンタウルス座","ra":13.9256,"dec":-47.28,"m":2.53,"s":"spring","o":"marshallese","w":"マーシャルの星","msg":"ケンタウルス座、マーシャル諸島語で命名された伝統名。\n小さな島々にも、自分たちだけの夜空がある。","st":"アクアマリン","sm":"南島を清める、水の輝き。"},{"d":107,"n":"Hadar","c":"ケンタウルス座","ra":14.0636,"dec":-60.37,"m":0.64,"s":"spring","o":"arabic","w":"半身の戦士","msg":"半人半馬ケンタウロスの体を持つ南天の星。矛盾を抱えたままで、進める。","st":"ラピスラズリ","sm":"矛盾に古代を宿す、深い藍。"},{"d":108,"n":"Thuban","c":"りゅう座","ra":14.0731,"dec":64.37,"m":3.65,"s":"spring","o":"arabic","w":"かつての北極星","msg":"りゅう座、アラビア語で「蛇」、紀元前2700年頃の北極星。中心も、時代とともに移ろう。","st":"クリアクオーツ","sm":"過去の北を清浄に保つ、白の結晶。"},{"d":109,"n":"Menkent","c":"ケンタウルス座","ra":14.1111,"dec":-36.37,"m":2.05,"s":"spring","o":"arabic","w":"ケンタウロスの肩","msg":"ケンタウルス座、アラビア語で「肩」＋「ケンタウロス」、半人半馬の右肩。\n二つの体を持つ者の肩は、二倍の責任を背負う。","st":"ローズクオーツ","sm":"肩を優しく抱く、桃色の石。"},{"d":110,"n":"Kang","c":"おとめ座","ra":14.2149,"dec":-10.27,"m":4.18,"s":"spring","o":"chinese","w":"龍の首","msg":"中国の星宿で『龍の首』、おとめ座に重なる古名。\n首は、頭と体を繋ぐ橋。\nどちらが欠けても、橋は意味を失う。","st":"ラピスラズリ","sm":"龍首に古代を宿す、深い藍。"},{"d":111,"n":"Arcturus","c":"うしかい座","ra":14.2611,"dec":19.18,"m":0.16,"s":"spring","o":"greek","w":"流転の旅人","msg":"ひとところに留まらない春の星。変わり続けるのは、強さだ。","st":"タイガーアイ","sm":"流転を貫く、金の眼差し。"},{"d":112,"n":"Syrma","c":"おとめ座","ra":14.2669,"dec":-6.0,"m":4.08,"s":"spring","o":"greek","w":"衣の裾","msg":"おとめ座、アラビア語で「裾を引きずる者」。地を歩む裾は、土を清めて歩く。","st":"ホワイトカルセドニー","sm":"裾を抱く、淡い白。"},{"d":113,"n":"Xuange","c":"うしかい座","ra":14.2731,"dec":46.08,"m":4.18,"s":"spring","o":"chinese","w":"天の槍","msg":"うしかい座、中国の単星星宿で「北の長槍」。\nまっすぐ天を指す槍は、迷いを許さない。","st":"レッドジャスパー","sm":"槍に根を張る、土の赤。"},{"d":114,"n":"Khambalia","c":"おとめ座","ra":14.3185,"dec":-13.37,"m":4.52,"s":"spring","o":"egyptian","w":"曲がった爪","msg":"おとめ座、コプト語で「曲がった爪」、おとめの足の星。\nまっすぐじゃない道のりにも、着く先がある。","st":"エメラルド","sm":"曲線を清める、深い翠。"},{"d":115,"n":"Kalasungsang","c":"うしかい座","ra":14.5303,"dec":30.37,"m":3.57,"s":"spring","o":"sanskrit","w":"時の番人","msg":"うしかい座、バリ語で「カーラ＝時」「スンサン＝逆さま」。\n時を無駄にするなと告げる古き名。\n逆さまから見ると、世界の形が変わる。","st":"オブシディアン","sm":"時の番人に芯を作る、火山の黒。"},{"d":116,"n":"Seginus","c":"うしかい座","ra":14.5344,"dec":38.3,"m":3.04,"s":"spring","o":"latin","w":"立つ脚","msg":"うしかい座、近代に名づけ直された脚の星。\n呼び名は移ろっても、果たす役目は変わらない。","st":"イエロージェード","sm":"立つ場所に滋養を宿す、黄のジェード。"},{"d":117,"n":"Genghe","c":"うしかい座","ra":14.578,"dec":29.73,"m":4.46,"s":"spring","o":"chinese","w":"天の槍 第二","msg":"うしかい座、中国名で「天の槍」三星のうちの第二星。\n後ろに二番目がいるから、一番は一番でいられる。","st":"レッドジャスパー","sm":"第二を地に結ぶ、力強い赤。"},{"d":118,"n":"Toliman","c":"ケンタウルス座","ra":14.6608,"dec":-60.83,"m":1.35,"s":"spring","o":"arabic","w":"男の足","msg":"ケンタウルス座、アラビア語で「ダチョウ二羽」。並んで歩く二人の歩幅は、いつのまにか似てくる。","st":"カーネリアン","sm":"並ぶ足を支える、生命の赤。"},{"d":119,"n":"Rigil Kentaurus","c":"ケンタウルス座","ra":14.6611,"dec":-60.83,"m":-0.01,"s":"spring","o":"arabic","w":"ケンタウロスの足","msg":"ケンタウルス座、アラビア語で「ケンタウロスの足」、太陽系最近の恒星系。\n4.3光年、もっとも近い隣人。\n身近な存在を、当たり前と思うな。","st":"カーネリアン","sm":"4.3光年の隣人の奥で燃える、勇気の赤。"},{"d":120,"n":"Uridim","c":"おおかみ座","ra":14.6986,"dec":-47.38,"m":2.29,"s":"spring","o":"sumerian","w":"野の番人","msg":"シュメール語で「野の主・狼」。\n人類最古の文明が、野生の力に名を与えた星。\n飼い慣らされないことを、罪にしてはいけない。","st":"スモーキークオーツ","sm":"野生の魂を包む、煙色の輝き。"},{"d":121,"n":"Xami","c":"コンパス座","ra":14.7083,"dec":-64.97,"m":3.16,"s":"spring","o":"african","w":"獅子の顔","msg":"コンパス座、南アフリカの星座で「ライオンの顔」。\nアルファ・ベータケンタウリの目に挟まれた、見えない顔。\n見えないものを見る目を、信じよ。","st":"タイガーアイ","sm":"獅子顔を見据える、虎の眼。"},{"d":122,"n":"Alrumh","c":"うしかい座","ra":14.7237,"dec":26.52,"m":4.8,"s":"spring","o":"arabic","w":"槍","msg":"うしかい座、アラビア語で「槍・矛」、四つの星を結ぶ古代アラブの星宿。\n振り上げる前の槍は、ただの棒。\n振り上げた瞬間に、意味が宿る。","st":"レッドジャスパー","sm":"槍に根を張る、土の赤。"},{"d":123,"n":"Izar","c":"うしかい座","ra":14.7497,"dec":27.07,"m":2.46,"s":"spring","o":"arabic","w":"腰布","msg":"うしかい座、アラビア語で「腰の帯」。まとうものは、その人の姿勢を作る。","st":"ロードナイト","sm":"腰布に柔らかさを贈る、ロードナイト。"},{"d":124,"n":"Maenalus","c":"おとめ座","ra":14.7706,"dec":1.88,"m":3.72,"s":"spring","o":"latin","w":"メーナロス山","msg":"おとめ座、ギリシャ・ペロポネソス半島の山に捧げられた星。\n地上の場所を、空に映す試みもある。","st":"エメラルド","sm":"山を育む、深い緑。"},{"d":125,"n":"Paradys","c":"ふうちょう座","ra":14.7975,"dec":-79.03,"m":3.81,"s":"spring","o":"contemporary","w":"極楽鳥","msg":"ふうちょう座、1598年プランキウスが付けた「極楽鳥」の名。\n見たことがないものの名は、想像が宿る。","st":"オパール","sm":"極楽鳥に虹を宿す、変幻の石。"},{"d":126,"n":"Solitaire","c":"うみへび座","ra":14.8381,"dec":-27.95,"m":4.42,"s":"spring","o":"contemporary","w":"孤独な鳥","msg":"うみへび座、絶滅したロドリゲス・ソリテア鳥に捧げられた星。\n失われたものを、夜空に残す優しさがある。","st":"ムーンストーン","sm":"喪失に月の力を宿す、白の輝き。"},{"d":127,"n":"Kochab","c":"こぐま座","ra":14.845,"dec":74.15,"m":2.06,"s":"spring","o":"arabic","w":"北を守る","msg":"こぐま座、紀元前3000年頃の北極星、アラビア語に由来。\n中心は時代と共に動く。\n動かないように見えて、動いている。","st":"ラピスラズリ","sm":"北を抱く、夜空の深青。"},{"d":128,"n":"Zubenelgenubi","c":"てんびん座","ra":14.8478,"dec":-16.03,"m":2.73,"s":"spring","o":"arabic","w":"南の爪","msg":"てんびん座、アラビア語で「南の爪」。元はさそりの爪だった星。境界に立つ者は、両側の景色を知っている。","st":"ブルーカルセドニー","sm":"境界に静けさを贈る、青の石。"},{"d":129,"n":"Nekkar","c":"うしかい座","ra":15.0322,"dec":40.38,"m":3.48,"s":"spring","o":"arabic","w":"うしかいの頭","msg":"うしかい座、アラビア語で「牛使いの頭」。頭で考える者は、足で稼ぐ者にいつか追いつかれる。","st":"ラピスラズリ","sm":"うしかい頭を覆う、ラピスの夜。"},{"d":130,"n":"Quadrans","c":"うしかい座","ra":15.0631,"dec":47.65,"m":4.7,"s":"spring","o":"latin","w":"四分儀","msg":"うしかい座、ラテン語で「四分儀」、1795年命名の廃止された星座。\n失われた星座にも、流星群の名前として残った。\n消えても、痕跡を残せ。","st":"クリスタル","sm":"四分儀を清める、クリスタルの輝き。"},{"d":131,"n":"Brachium","c":"てんびん座","ra":15.0678,"dec":-25.27,"m":3.28,"s":"spring","o":"latin","w":"差し伸べる腕","msg":"てんびん座、ラテン語で「腕」。\n振り上げる腕より、差し伸べる腕が美しい。","st":"ロードナイト","sm":"差し伸べる腕を解きほぐす、優しい桃色。"},{"d":132,"n":"Qigong","c":"うしかい座","ra":15.2583,"dec":33.3,"m":3.46,"s":"spring","o":"chinese","w":"七公","msg":"うしかい座、中国名で「七人の高位者」。\n七人の合議は、一人の決断より遅いが、揺るがない。","st":"ヒスイ","sm":"七人を保つ、皇の翡翠。"},{"d":133,"n":"Zubeneschamali","c":"てんびん座","ra":15.2833,"dec":-9.37,"m":2.61,"s":"spring","o":"arabic","w":"北の爪","msg":"てんびん座、アラビア語で「北の爪」。秤を保つには、両側に同じ重みがいる。","st":"エメラルド","sm":"秤を育む、深い緑。"},{"d":134,"n":"Pherkad","c":"こぐま座","ra":15.3453,"dec":71.83,"m":3.03,"s":"spring","o":"arabic","w":"北を指す子","msg":"こぐま座、アラビア語で「子牛」。小さき者にも、北を指す役目がある。","st":"イエロージェード","sm":"小さな子牛に滋養を宿す、黄のジェード。"},{"d":135,"n":"Alkalurops","c":"うしかい座","ra":15.4082,"dec":37.37,"m":4.31,"s":"spring","o":"latin","w":"牧人の杖","msg":"うしかい座、ギリシャ語で「羊飼いの杖」。振りかぶる前に、地に突くものを持て。","st":"スモーキークオーツ","sm":"牧人杖を包む、煙色の輝き。"},{"d":136,"n":"Edasich","c":"りゅう座","ra":15.4153,"dec":58.95,"m":3.3,"s":"spring","o":"arabic","w":"ひとつの太陽","msg":"りゅう座、アラビア語で「ハイエナ」。華やかでなくても、君を真ん中に回る世界が、どこかにある。","st":"スモーキークオーツ","sm":"夜の動物を抱きしめる、煙の石。"},{"d":137,"n":"Nusakan","c":"かんむり座","ra":15.4636,"dec":29.1,"m":3.64,"s":"spring","o":"arabic","w":"二本の線","msg":"かんむり座、アラビア語で「二列の星々」、ヘルクレス〜こと座にまたがった古代の星宿。\n二本の線は、交わって初めて、ひとつの形になる。","st":"ターコイズ","sm":"交差に風を運ぶ、ターコイズ。"},{"d":138,"n":"Alphecca","c":"かんむり座","ra":15.5781,"dec":26.7,"m":2.22,"s":"spring","o":"arabic","w":"冠の宝石","msg":"半円のかんむり座の中央で輝く。中心にいる時こそ、頭を低く保て。","st":"クリアクオーツ","sm":"冠宝石を清浄に保つ、白の結晶。"},{"d":139,"n":"Zubenelhakrabi","c":"てんびん座","ra":15.5919,"dec":-14.78,"m":3.92,"s":"spring","o":"arabic","w":"蠍の爪","msg":"てんびん座、アラビア語で「蠍の爪」。\nてんびん座は、もとはさそりの爪だった。\n体の一部が独立して、新しい姿になることもある。","st":"ガーネット","sm":"蠍の爪に情熱を宿す、深紅の宝石。"},{"d":140,"n":"Unukalhai","c":"へび座","ra":15.7378,"dec":6.42,"m":2.63,"s":"spring","o":"arabic","w":"蛇の首","msg":"へび座、アラビア語で「蛇の首」。蛇遣いに掴まれた首は、咬む側でなく咬まれる側に近い。","st":"エメラルド","sm":"蛇の首に若さを宿す、エメラルドの輝き。"},{"d":141,"n":"Zhou","c":"へび座","ra":15.7697,"dec":15.42,"m":3.64,"s":"spring","o":"chinese","w":"天の市場","msg":"へび座、中国名で「天市垣」の星のひとつ。\n天の市場には、神々も商いに来る。","st":"ローズクオーツ","sm":"市場を優しく抱く、桃色の石。"},{"d":142,"n":"Gudja","c":"へび座","ra":15.8123,"dec":18.13,"m":4.09,"s":"spring","o":"aboriginal","w":"リザード","msg":"へび座、豪州先住民ワダマン族の伝統名。小さな生き物にも、空にいる場所がある。","st":"タイガーアイ","sm":"リザードを見据える、虎の眼。"},{"d":143,"n":"Iklil","c":"さそり座","ra":15.9481,"dec":-29.2,"m":3.85,"s":"spring","o":"arabic","w":"蠍の冠","msg":"さそり座、アラビア語で「冠」、さそりの頭の冠。王の証は、冠ではなく、冠を被る覚悟の方にある。","st":"クリアクオーツ","sm":"冠を映す、透明な石。"},{"d":144,"n":"Fang","c":"さそり座","ra":15.9808,"dec":-26.1,"m":2.89,"s":"spring","o":"chinese","w":"部屋","msg":"さそり座、紀元前3千年紀の中国の月宿で「部屋」、四つの星から成る。\n部屋は、外界から守られる場所。\n戻れる場所を持つ者は、遠くへ行ける。","st":"ラピスラズリ","sm":"部屋を覆う、ラピスの夜。"},{"d":145,"n":"Blaze Star","c":"かんむり座","ra":15.9917,"dec":25.92,"m":2.0,"s":"spring","o":"english","w":"炎の星","msg":"かんむり座、英語で「燃え盛る星」、再帰新星T CrB のニックネーム。\n爆発を繰り返す星は、何度でもやり直せる。","st":"ガーネット","sm":"炎に情熱を宿す、深紅の宝石。"},{"d":146,"n":"Dschubba","c":"さそり座","ra":16.0056,"dec":-22.62,"m":2.3,"s":"spring","o":"arabic","w":"蠍の額","msg":"さそり座、アラビア語で「蠍の額」。\n額に何が刻まれているかで、その人の物語が決まる。","st":"ラピスラズリ","sm":"蠍額に古代を宿す、深い藍。"},{"d":147,"n":"Acrab","c":"さそり座","ra":16.0906,"dec":-19.8,"m":2.62,"s":"spring","o":"arabic","w":"蠍","msg":"さそり座、アラビア語で「蠍」、まさに星座そのもの。本質を名にする者は、それ以上を語らない。","st":"レッドガーネット","sm":"本質を貫く、深い赤の石。"},{"d":148,"n":"Jabbah","c":"さそり座","ra":16.1999,"dec":-19.45,"m":4.0,"s":"spring","o":"arabic","w":"さそりの額","msg":"さそり座、アラビア語で「額」。額は、思考が現れる場所。隠せないからこそ、磨く価値がある。","st":"ラピスラズリ","sm":"さそり額を抱く、夜空の深青。"},{"d":149,"n":"Yed Prior","c":"へびつかい座","ra":16.2389,"dec":-3.68,"m":2.73,"s":"spring","o":"arabic","w":"前の手","msg":"へびつかい座、アラビア語で「前の手」、蛇遣いの右手。手で蛇を掴む覚悟は、誰にでもできるものじゃない。","st":"カーネリアン","sm":"前の手に火を灯す、温かな赤の石。"},{"d":150,"n":"Yed Posterior","c":"へびつかい座","ra":16.3053,"dec":-4.68,"m":3.24,"s":"spring","o":"arabic","w":"後ろの手","msg":"へびつかい座、アラビア語で「後ろの手」、蛇遣いの左手。右だけが大事じゃない。前に出る手の後ろで、もう一方の手が静かに支えている。","st":"ローズクオーツ","sm":"後ろの手に愛を宿す、ローズの輝き。"},{"d":151,"n":"Alniyat","c":"さそり座","ra":16.3531,"dec":-25.58,"m":2.9,"s":"spring","o":"arabic","w":"心臓の脈","msg":"さそり座、アラビア語で「動脈」、心臓アンタレスを挟む星のひとつ。\n動脈は、心臓と末端を繋ぐ命の道。\n誰かと自分を繋ぐ動脈を、大切に。","st":"レッドガーネット","sm":"動脈を貫く、深い赤の石。"},{"d":152,"n":"Athebyne","c":"りゅう座","ra":16.3997,"dec":61.5,"m":2.73,"s":"spring","o":"arabic","w":"二匹の狼","msg":"りゅう座、アラビア語で「二匹の狼」、子ラクダを狙う星々。\n群れる者には、群れる理由がある。","st":"スモーキークオーツ","sm":"狼に静けさを宿す、煙水晶。"},{"d":153,"n":"Cujam","c":"ヘルクレス座","ra":16.4236,"dec":14.02,"m":4.5821,"s":"spring","o":"latin","w":"棍棒","msg":"ヘルクレス座、ラテン語で「棍棒」、ヘラクレスの武器。\n振りかぶる時間が、武器の重さを決める。","st":"ヘマタイト","sm":"棍棒に芯を宿す、鉄黒の石。"},{"d":154,"n":"Antares","c":"さそり座","ra":16.49,"dec":-26.42,"m":1.07,"s":"spring","o":"greek","w":"燃える心臓","msg":"火星のライバルと呼ばれる赤、さそりの心臓。冷静より、熱さを選ぶ日があってもいい。","st":"ルビー","sm":"燃える心臓を心臓のように脈打つ赤。"},{"d":155,"n":"Kornephoros","c":"ヘルクレス座","ra":16.5036,"dec":21.48,"m":2.78,"s":"spring","o":"greek","w":"棍棒持ち","msg":"ヘルクレス座、ギリシャ語で「棍棒を持つ者」、ヘラクレスの異名。\n強さは、武器を持つ手の覚悟に宿る。","st":"レッドジャスパー","sm":"武器持ちに根を張る、土の赤。"},{"d":156,"n":"Marfik","c":"へびつかい座","ra":16.5152,"dec":1.98,"m":3.82,"s":"spring","o":"arabic","w":"蛇遣いの肘","msg":"へびつかい座、アラビア語で「肘」。曲げられる場所が、強さを作る。","st":"ロードナイト","sm":"蛇遣いの肘に柔らかさを贈る、ロードナイト。"},{"d":157,"n":"Paikauhale","c":"さそり座","ra":16.5978,"dec":-28.2,"m":2.78,"s":"spring","o":"polynesian","w":"放浪者","msg":"さそり座、ハワイ語に由来する星。\n家を持たないことは、世界中を家にすること。","st":"スモーキークオーツ","sm":"放浪を抱きしめる、煙の石。"},{"d":158,"n":"Atria","c":"みなみのさんかく座","ra":16.8108,"dec":-69.02,"m":1.9,"s":"summer","o":"latin","w":"静かな三角","msg":"南天の小さな三角形のひとつ。小さくても、形を成すものには美しさが宿る。","st":"ガーネット","sm":"静かな三角を燃やす、ガーネットの赤。"},{"d":159,"n":"Larawag","c":"さそり座","ra":16.8358,"dec":-34.28,"m":2.27,"s":"summer","o":"aboriginal","w":"見据える眼","msg":"さそり座、豪州先住民ワダマン族の言葉。見据えた先があるから、長い夜も歩いていける。","st":"タイガーアイ","sm":"見据える眼を貫く、金の眼差し。"},{"d":160,"n":"Xamidimura","c":"さそり座","ra":16.8644,"dec":-38.03,"m":3.0,"s":"summer","o":"african","w":"夜に光る獅子の眼","msg":"さそり座、ナマ語で「獅子の眼」、南アフリカの伝統名。\n獅子の眼で見ると、人間の世界が小さく見える。","st":"タイガーアイ","sm":"夜に光る獅子の眼を見据える、虎の眼。"},{"d":161,"n":"Pipirima","c":"さそり座","ra":16.8722,"dec":-38.02,"m":3.53,"s":"summer","o":"polynesian","w":"双子の子供","msg":"さそり座、ポリネシアの伝説で、冷たい親から逃げ星になった双子。\n見捨てられた者が、誰かの星になる物語。","st":"ローズクオーツ","sm":"双子を優しく抱く、桃色の石。"},{"d":162,"n":"Alrakis","c":"りゅう座","ra":17.0889,"dec":54.47,"m":3.429,"s":"summer","o":"arabic","w":"駆けるラクダ","msg":"りゅう座、アラビア語で「速歩のラクダ」。\n砂漠を渡るラクダは、急がないが止まらない。","st":"イエロージャスパー","sm":"ラクダに安定を宿す、黄のジャスパー。"},{"d":163,"n":"Aldhibah","c":"りゅう座","ra":17.1464,"dec":65.7,"m":3.18,"s":"summer","o":"arabic","w":"ハイエナ","msg":"りゅう座、アラビア語で「ハイエナ」。孤立した名にも、誇りはある。","st":"スモーキークオーツ","sm":"野生を抱きしめる、煙の石。"},{"d":164,"n":"Sabik","c":"へびつかい座","ra":17.1728,"dec":-15.72,"m":2.43,"s":"summer","o":"arabic","w":"先行する者","msg":"へびつかい座、アラビア語で「先行する」。先に動く者は、後から動く者の道をつくる。","st":"タイガーアイ","sm":"先行するに勇気を宿す、虎眼石。"},{"d":165,"n":"Rasalgethi","c":"ヘルクレス座","ra":17.2439,"dec":14.38,"m":3.34,"s":"summer","o":"arabic","w":"跪く者の頭","msg":"ヘルクレス座、アラビア語で「跪く者の頭」、ヘラクレスの古い呼び名。\n跪く時間は、立ち上がる時間より大切。","st":"レッドカーネリアン","sm":"跪く者を駆動する、勇気の赤。"},{"d":166,"n":"Sarin","c":"ヘルクレス座","ra":17.2503,"dec":24.83,"m":3.11,"s":"summer","o":"contemporary","w":"戦士の鎧","msg":"ヘルクレス座、近代命名。まとう鎧は、内側を守るためのもの。","st":"ヘマタイト","sm":"鎧を地に置く、深黒の石。"},{"d":167,"n":"Franz","c":"ヘルクレス座","ra":17.3411,"dec":38.23,"m":3.2,"s":"summer","o":"contemporary","w":"オーストリア皇帝","msg":"ヘルクレス座、映画「シシィ」のフランツ皇帝役から命名。\n名前は、誰かに呼ばれ続けるかぎり、消えない。","st":"ガーネット","sm":"オーストリア皇帝を燃やす、ガーネットの赤。"},{"d":168,"n":"Rastaban","c":"りゅう座","ra":17.5069,"dec":52.3,"m":2.8,"s":"summer","o":"arabic","w":"竜の頭","msg":"りゅう座、アラビア語で「竜の頭」。威圧的な名前にも、優しい光がある。","st":"ブルートパーズ","sm":"威厳を澄ませる、青のトパーズ。"},{"d":169,"n":"Maasym","c":"ヘルクレス座","ra":17.5123,"dec":26.1,"m":4.41,"s":"summer","o":"arabic","w":"ヘルクレスの腕","msg":"ヘルクレス座、アラビア語で『手首』。\nぎょしゃ座のMahasimと、千年前は同じ名だった。\n英雄の腕も、地味なひと振りの繰り返しでできている。","st":"ロードナイト","sm":"ヘルクレスの腕にしなやかさを宿す、桜色の石。"},{"d":170,"n":"Lesath","c":"さそり座","ra":17.5125,"dec":-37.28,"m":2.64,"s":"summer","o":"arabic","w":"霧の集まり","msg":"さそり座、ギリシャ語に由来、プトレマイオスが「霧状の塊」と記した星。\n輪郭がぼやけているものにも、確かな存在感がある。","st":"ムーンストーン","sm":"霧に月の力を宿す、白の輝き。"},{"d":171,"n":"Yildun","c":"こぐま座","ra":17.5369,"dec":86.58,"m":4.36,"s":"summer","o":"arabic","w":"星","msg":"こぐま座、トルコ語で「星」。飾らない名前ほど、長く呼ばれて残る。","st":"クリアクオーツ","sm":"原初を清浄に保つ、白の結晶。"},{"d":172,"n":"Shaula","c":"さそり座","ra":17.56,"dec":-37.1,"m":1.63,"s":"summer","o":"sumerian","w":"上げられた針","msg":"さそりの尾の先、アラビア語で「上げられたもの」。誰かを傷つける力を、自分を守るために使え。","st":"ブルーアパタイト","sm":"鋭さに集中を宿す、青のアパタイト。"},{"d":173,"n":"Rasalhague","c":"へびつかい座","ra":17.5822,"dec":12.55,"m":2.09,"s":"summer","o":"arabic","w":"蛇遣いの首","msg":"蛇を持つ医神アスクレピオスの頭。毒も、扱い方次第で薬になる。","st":"クリアクオーツ","sm":"毒を映す、透明な石。"},{"d":174,"n":"Sargas","c":"さそり座","ra":17.6219,"dec":-42.98,"m":1.86,"s":"summer","o":"sumerian","w":"弓を引く","msg":"さそりの尾、力をためる場所、シュメール語由来。出さない強さの方が、出す強さより難しい。","st":"イエロートルマリン","sm":"弓を引くを満たす、黄のトルマリン。"},{"d":175,"n":"Cebalrai","c":"へびつかい座","ra":17.7244,"dec":4.57,"m":2.75,"s":"summer","o":"arabic","w":"羊飼いの犬","msg":"へびつかい座、アラビア語で「羊飼いの犬」。誰かを守る役目に、誇りを持っていい。","st":"スモーキークオーツ","sm":"守る者を抱きしめる、煙の石。"},{"d":176,"n":"Bake-eo","c":"へびつかい座","ra":17.7981,"dec":2.7,"m":3.73,"s":"summer","o":"marshallese","w":"貝殻","msg":"へびつかい座、マーシャル諸島語で「ここに貝あり」。\n声に出して名を呼ぶことで、その存在は確かになる。","st":"アクアマリン","sm":"南島を流れに乗せる、澄んだ青。"},{"d":177,"n":"Fuyue","c":"さそり座","ra":17.8308,"dec":-37.03,"m":3.19,"s":"summer","o":"chinese","w":"賢臣","msg":"さそり座、紀元前18世紀の中国の伝説の宰相、過誤を告げる役。\n王に「違う」と言える臣下は、王より長く名が残る。","st":"ヒスイ","sm":"賢臣を保つ、皇の翡翠。"},{"d":178,"n":"Grumium","c":"りゅう座","ra":17.8919,"dec":56.87,"m":3.73,"s":"summer","o":"latin","w":"竜の顎","msg":"りゅう座、ラテン語で「顎」。噛みしめる時が、いちばん力が出る。","st":"オニキス","sm":"竜顎に静けさを宿す、深い黒。"},{"d":179,"n":"Eltanin","c":"りゅう座","ra":17.9433,"dec":51.48,"m":2.23,"s":"summer","o":"arabic","w":"蛇","msg":"りゅう座、アラビア語で「蛇」、りゅう座そのものの名。\n蛇は、地と空を繋ぐ生き物。\n上下を繋ぐ役にも、誇りがある。","st":"エメラルド","sm":"蛇に若さを宿す、エメラルドの輝き。"},{"d":180,"n":"Alnasl","c":"いて座","ra":18.0967,"dec":-30.42,"m":2.96,"s":"summer","o":"arabic","w":"矢の先","msg":"いて座、アラビア語で「矢の先端」。\n放たれた矢の先には、決めた行き先がある。","st":"レッドジャスパー","sm":"矢を地に結ぶ、力強い赤。"},{"d":181,"n":"Ramus","c":"ヘルクレス座","ra":18.146,"dec":20.8,"m":4.37,"s":"summer","o":"latin","w":"黄金の枝","msg":"ヘルクレス座、ラテン語で「枝」、黄金のリンゴの枝。\n枝の先には、いつも何か実っている。","st":"エメラルド","sm":"枝を育む、深い緑。"},{"d":182,"n":"Polis","c":"いて座","ra":18.2292,"dec":-21.05,"m":3.84,"s":"summer","o":"greek","w":"都市","msg":"いて座、ギリシャ語で「都市」。集まりの中心にいる者は、孤独を選ばない。","st":"ラピスラズリ","sm":"都市に古代を宿す、深い藍。"},{"d":183,"n":"Kaus Media","c":"いて座","ra":18.3497,"dec":-29.82,"m":2.68,"s":"summer","o":"arabic","w":"弓の中央","msg":"いて座の弓の真ん中、力の集まる点。バランスとは、両端を見ながら立つこと。","st":"アズライト","sm":"弓の中央に集中を宿す、深い藍。"},{"d":184,"n":"Tusizuo","c":"ヘルクレス座","ra":18.395,"dec":21.77,"m":3.85,"s":"summer","o":"chinese","w":"節目の場","msg":"ヘルクレス座、漢代の中国の二星星宿で「屠殺場」。\n人生の節目には、立ち止まっていい場所がある。","st":"ガーネット","sm":"節目の場に情熱を宿す、深紅の宝石。"},{"d":185,"n":"Kaus Australis","c":"いて座","ra":18.4028,"dec":-34.38,"m":1.81,"s":"summer","o":"arabic","w":"南の弓","msg":"いて座の弓の下端。射る前に、引く時間がいちばん大事。","st":"アズライト","sm":"南の弓に集中を宿す、深い藍。"},{"d":186,"n":"Kaus Borealis","c":"いて座","ra":18.4661,"dec":-25.42,"m":2.81,"s":"summer","o":"arabic","w":"北の弓","msg":"いて座の弓の上端、放つ前の張り。方向が定まれば、矢は放たれる前に届く。","st":"アズライト","sm":"北の弓を貫く、藍の輝き。"},{"d":187,"n":"Vega","c":"こと座","ra":18.6156,"dec":38.77,"m":0.03,"s":"summer","o":"arabic","w":"織り続ける手","msg":"七夕の織姫。途中で投げ出さずに紡げ、その糸はやがて空を渡る。","st":"サファイア","sm":"織り続ける手に深さを宿す、王の青。"},{"d":188,"n":"Sheliak","c":"こと座","ra":18.8344,"dec":33.35,"m":3.63,"s":"summer","o":"arabic","w":"琴のブリッジ","msg":"こと座、アラビア語で「亀の甲羅」、もとはハープの胴。音を響かせるのは、空洞の部分。","st":"クリアクオーツ","sm":"音を映す、透明な石。"},{"d":189,"n":"Nunki","c":"いて座","ra":18.9208,"dec":-26.28,"m":2.07,"s":"summer","o":"sumerian","w":"ためられた力","msg":"いて座の手の中の星、シュメール語に由来。蓄えてきたものを、出すべき時に出せるか。","st":"ラピスラズリ","sm":"蓄えた力を覆う、ラピスの夜。"},{"d":190,"n":"Alya","c":"へび座","ra":18.9369,"dec":4.2,"m":4.58,"s":"summer","o":"arabic","w":"羊の脂尾","msg":"へび座、アラビア語で「東洋種の羊の太い脂尾」。\n誤って Alioth の語源とされた、紛らわしい名。\n誤読は、新しい意味の入り口。","st":"カーネリアン","sm":"脂尾を支える、生命の赤。"},{"d":191,"n":"Sulafat","c":"こと座","ra":18.9822,"dec":32.68,"m":3.22,"s":"summer","o":"arabic","w":"亀","msg":"こと座、アラビア語で「亀」、リラの胴体になぞらえた名。\n亀の甲羅が、音を響かせる楽器になった。\n硬い殻にも、音楽が宿る。","st":"タイガーアイ","sm":"亀に勇気を宿す、虎眼石。"},{"d":192,"n":"Ascella","c":"いて座","ra":19.0433,"dec":-29.87,"m":2.61,"s":"summer","o":"latin","w":"脇腹","msg":"いて座、ラテン語で「脇」。脇は、力の入らない場所だからこそ、しなやかでいられる。","st":"ローズクオーツ","sm":"柔らかさを温める、桜色の石。"},{"d":193,"n":"Okab","c":"わし座","ra":19.09,"dec":13.85,"m":2.95,"s":"summer","o":"arabic","w":"鷲の尾","msg":"わし座、アラビア語で「鷲の尾」、本来は ζ-ε Aql の名。\n尾は、方向を決める舵。\n進路を決めるのは、翼ではなく、尾のひと動きだ。","st":"ブルートパーズ","sm":"尾を照らす、透き通る青。"},{"d":194,"n":"Meridiana","c":"みなみのかんむり座","ra":19.1579,"dec":-37.9,"m":4.09,"s":"summer","o":"latin","w":"真昼の冠","msg":"みなみのかんむり座、ラテン＋アラビア語で「南の宝石冠」。\n南の冠は、北の冠より低く輝く。\n低い場所からの視点を、忘れるな。","st":"クリアクオーツ","sm":"南冠を映す、透明な石。"},{"d":195,"n":"Albaldah","c":"いて座","ra":19.1625,"dec":-21.02,"m":2.9,"s":"summer","o":"arabic","w":"空き地","msg":"いて座、アラビア語で「空地」、星のない領域の名。\n何もない場所にも、名前がある。\n空白は、誰かに埋められるのを待っている。","st":"ホワイトカルセドニー","sm":"空き地を受け取る、白の石。"},{"d":196,"n":"Altais","c":"りゅう座","ra":19.2092,"dec":67.65,"m":3.06,"s":"summer","o":"arabic","w":"誤読の蛇","msg":"りゅう座、アラビア語の「蛇」を誤読した名前。\n誤読が、新しい星の名前を生むこともある。","st":"エメラルド","sm":"誤読を育む、深い緑。"},{"d":197,"n":"Aladfar","c":"こと座","ra":19.2293,"dec":39.13,"m":4.43,"s":"summer","o":"arabic","w":"鷲の爪","msg":"こと座、アラビア語で「急降下する鷲の爪」、こと座の二星の名。\n爪は、掴む瞬間にしか開かない。","st":"レッドジャスパー","sm":"爪に根を張る、土の赤。"},{"d":198,"n":"Arkab Prior","c":"いて座","ra":19.3772,"dec":-44.45,"m":3.94,"s":"summer","o":"arabic","w":"射手の腱・前","msg":"いて座、アラビア語で「射手のアキレス腱・前」。\n見えない場所の腱が、すべての動きを支える。","st":"カーネリアン","sm":"腱を支える、生命の赤。"},{"d":199,"n":"Arkab Posterior","c":"いて座","ra":19.387,"dec":-44.78,"m":4.29,"s":"summer","o":"arabic","w":"射手の腱・後","msg":"いて座、アラビア語で「射手のアキレス腱・後」。\n弓を引く力は、二本の腱が逆に働いて生まれる。","st":"カーネリアン","sm":"腱の奥で燃える、勇気の赤。"},{"d":200,"n":"Rukbat","c":"いて座","ra":19.3981,"dec":-40.6,"m":3.94,"s":"summer","o":"arabic","w":"射手の膝","msg":"いて座、アラビア語で『射手の膝』。\n射る前に、止まる時間がある。","st":"ブルーアパタイト","sm":"構えに集中を宿す、青のアパタイト。"},{"d":201,"n":"Anser","c":"こぎつね座","ra":19.4784,"dec":24.65,"m":4.4,"s":"summer","o":"latin","w":"鵞鳥","msg":"こぎつね座、ラテン語で「鵞鳥」、ヘヴェリウスが「鵞鳥を抱えた小狐」と名付けた星座から。\n小さな存在だからと、隅に置かれる理由はない。","st":"ホワイトムーンストーン","sm":"鳥を月光で清める、白の石。"},{"d":202,"n":"Albireo","c":"はくちょう座","ra":19.5119,"dec":27.95,"m":3.07,"s":"summer","o":"arabic","w":"くちばしの星","msg":"はくちょう座のくちばし、青と金の二重星で名高い。相反する色も、寄り添えば調和する。","st":"ブルートパーZ","sm":"二色の調和を澄ませる、青の宝石。"},{"d":203,"n":"Alsafi","c":"りゅう座","ra":19.5393,"dec":69.65,"m":4.674,"s":"summer","o":"arabic","w":"竈の三脚","msg":"りゅう座、アラビア語で「竈の三脚」、遊牧民の野外調理具。\n三本の脚は、一本でも欠けたら立たない。","st":"イエロージャスパー","sm":"竈を支える、大地の黄色。"},{"d":204,"n":"Sham","c":"や座","ra":19.6683,"dec":18.0,"m":4.38,"s":"summer","o":"arabic","w":"矢","msg":"や座、アラビア語で「矢」。放たれた矢は、軌道を変えない。決めたら、戻らないでいい。","st":"レッドジャスパー","sm":"矢を地に結ぶ、力強い赤。"},{"d":205,"n":"Fawaris","c":"はくちょう座","ra":19.7494,"dec":45.12,"m":2.91,"s":"summer","o":"arabic","w":"騎士たち","msg":"はくちょう座、アラビア語で「騎士たち」、四つの星を結ぶ星宿の代表。\n一人の騎士の名が、群れ全体を表す。","st":"ヘマタイト","sm":"騎士を地に置く、深黒の石。"},{"d":206,"n":"Tarazed","c":"わし座","ra":19.7708,"dec":10.6,"m":2.69,"s":"summer","o":"persian","w":"天秤の星","msg":"わし座、ペルシア語で「秤」。量る者は、量られる側に立つ覚悟も持つ。","st":"ブルートパーズ","sm":"秤に清らかさを宿す、青の宝石。"},{"d":207,"n":"Altair","c":"わし座","ra":19.8461,"dec":8.87,"m":0.93,"s":"summer","o":"arabic","w":"翔ける鷲","msg":"夏の大三角の一角、七夕の彦星。細部より、構図を見よ。","st":"クリアクオーツ","sm":"翔ける鷲を清浄に保つ、白の結晶。"},{"d":208,"n":"Libertas","c":"わし座","ra":19.9041,"dec":8.45,"m":4.722,"s":"summer","o":"latin","w":"自由","msg":"わし座、ラテン語で「自由」。\n自由を奪われた人々を忘れないために、空に刻まれた星。","st":"クリアクオーツ","sm":"自由を澄ませる、清らかな水晶。"},{"d":209,"n":"Alshain","c":"わし座","ra":19.9217,"dec":6.4,"m":3.72,"s":"summer","o":"persian","w":"天秤の梁","msg":"わし座、ペルシア語で「秤の梁」、α・β・γ Aqlの古い名。\n梁が水平でなければ、秤は機能しない。\n水平を保つことが、いちばん難しい。","st":"ブルートパーズ","sm":"秤に清らかさを宿す、青の宝石。"},{"d":210,"n":"Terebellum","c":"いて座","ra":19.9307,"dec":-26.28,"m":4.7,"s":"summer","o":"latin","w":"四つ星","msg":"いて座、ラテン語で「四つ角」。四つの星が並んで、一つの形をつくる。","st":"エメラルド","sm":"四つの光を結ぶ、深い翠の石。"},{"d":211,"n":"Antinous","c":"わし座","ra":20.1883,"dec":-0.82,"m":3.25,"s":"summer","o":"greek","w":"愛された者","msg":"わし座、プトレマイオスが137年に作った副星座、ハドリアヌスの愛人の名。\n愛された者の名が、千年後も星に残る。","st":"ローズクオーツ","sm":"愛を包み込む、優しいピンク。"},{"d":212,"n":"Algedi","c":"やぎ座","ra":20.3008,"dec":-12.53,"m":3.58,"s":"summer","o":"arabic","w":"山羊の頭","msg":"やぎ座、アラビア語で「子山羊」、やぎ座そのものの名。\n小さき者が、星座の名になる。\n大きさじゃない、形が大事。","st":"イエロージャスパー","sm":"子山羊を支える、大地の黄色。"},{"d":213,"n":"Alshat","c":"やぎ座","ra":20.3444,"dec":-12.75,"m":4.76,"s":"summer","o":"arabic","w":"捧げられた羊","msg":"やぎ座、アラビア語の「祝祭で捧げられる」星宿の星。\n犠牲を意味する名にも、幸運の文字が添えられる。","st":"レッドガーネット","sm":"犠牲を貫く、深い赤の石。"},{"d":214,"n":"Dabih","c":"やぎ座","ra":20.35,"dec":-14.77,"m":3.07,"s":"summer","o":"arabic","w":"祭儀の主","msg":"やぎ座、アラビア語で「祝祭を司る者」。場を整える者がいるから、儀式は祈りになる。","st":"レッドジャスパー","sm":"儀式を支える、大地の赤。"},{"d":215,"n":"Sadr","c":"はくちょう座","ra":20.3703,"dec":40.25,"m":2.2,"s":"summer","o":"arabic","w":"白鳥の胸","msg":"はくちょう座、アラビア語で「胸」、はくちょう座の中心。胸の中の音を聞く時間を、毎日持て。","st":"ローズクオーツ","sm":"胸の中を包み込む、優しいピンク。"},{"d":216,"n":"Peacock","c":"くじゃく座","ra":20.4272,"dec":-56.73,"m":1.92,"s":"summer","o":"english","w":"千の眼","msg":"くじゃく座の翼、孔雀の羽の眼。見られている前提で動けるのは、覚悟だ。","st":"ラブラドライト","sm":"千の眼を持つ虹色の石。"},{"d":217,"n":"Aldulfin","c":"いるか座","ra":20.5535,"dec":11.3,"m":4.03,"s":"summer","o":"arabic","w":"イルカの背鰭","msg":"いるか座、アラビア語で「イルカ」、ギリシャ語からの借用。\nイルカは、笑っているように見える知恵者。","st":"アクアマリン","sm":"海豚を澄ませる、海の青。"},{"d":218,"n":"Rotanev","c":"いるか座","ra":20.6256,"dec":14.58,"m":3.63,"s":"summer","o":"latin","w":"逆さの名","msg":"いるか座、近代逆さ綴りの命名（学者Venator）。名前は逆から読んでも、星は変わらない。","st":"クリスタル","sm":"名のいたずらを清める、クリスタルの輝き。"},{"d":219,"n":"Sualocin","c":"いるか座","ra":20.6606,"dec":15.9,"m":3.78,"s":"summer","o":"latin","w":"学者の影","msg":"いるか座、19世紀の天文学者ニコラウスの名前を逆さ綴り。名前は遊びの中にも宿る。","st":"クリアクオーツ","sm":"名のいたずらを清浄に保つ、白の結晶。"},{"d":220,"n":"Deneb","c":"はくちょう座","ra":20.6903,"dec":45.27,"m":1.33,"s":"summer","o":"arabic","w":"夏の尾翼","msg":"はるか1500光年からの光、はくちょう座の尾。君の声は、思っているより遠くまで届く。","st":"ホワイトクオーツ","sm":"夏尾翼に澄み切る、白のクォーツ。"},{"d":221,"n":"Aljanah","c":"はくちょう座","ra":20.77,"dec":33.97,"m":2.46,"s":"summer","o":"arabic","w":"白鳥の翼","msg":"はくちょう座、アラビア語で「翼」、白鳥の翼の星。\n翼を持つ者は、翼を畳む時を知る。","st":"ブルートパーズ","sm":"翼に清らかさを宿す、青の宝石。"},{"d":222,"n":"Albali","c":"みずがめ座","ra":20.7944,"dec":-9.48,"m":3.76,"s":"summer","o":"arabic","w":"飲み込む者","msg":"みずがめ座、アラビア語で「飲み込む者」。受け入れる力は、押し返す力より強い。","st":"アクアマリン","sm":"受け入れる力を清める、水の輝き。"},{"d":223,"n":"Udang","c":"やぎ座","ra":21.0991,"dec":-17.22,"m":4.07,"s":"summer","o":"balinese","w":"海老","msg":"やぎ座、バリ語で「海老」、1300年続くバリの星暦に由来。\n海老は、後ろ向きにも器用に進む。\n前に進めない時は、横に進めばいい。","st":"カーネリアン","sm":"海老の奥で燃える、勇気の赤。"},{"d":224,"n":"Kitalpha","c":"こうま座","ra":21.2636,"dec":5.23,"m":3.94,"s":"summer","o":"arabic","w":"馬の半分","msg":"こうま座、アラビア語で「馬の一部」、こうま座そのもの。\n半分しか描かれない馬にも、走る姿がある。","st":"イエロージェード","sm":"馬に滋養を宿す、黄のジェード。"},{"d":225,"n":"Alderamin","c":"ケフェウス座","ra":21.3094,"dec":62.58,"m":2.47,"s":"summer","o":"arabic","w":"右腕","msg":"ケフェウス座、アラビア語で「右腕」と理解されてきた古名。\n名前の由来が誤解だとしても、その意味は生き続ける。","st":"スモーキークオーツ","sm":"腕を包む、煙色の輝き。"},{"d":226,"n":"Alfirk","c":"ケフェウス座","ra":21.4775,"dec":70.55,"m":3.23,"s":"summer","o":"arabic","w":"群れ","msg":"ケフェウス座、アラビア語で「群れ」。群れの中で、誰とも違う光になれ。","st":"ターコイズ","sm":"群れの中を守る、空色の石。"},{"d":227,"n":"Sadalsuud","c":"みずがめ座","ra":21.5258,"dec":-5.57,"m":2.89,"s":"summer","o":"arabic","w":"幸運の幸運","msg":"みずがめ座、アラビア語で「最幸運」。二重に幸運な日もある。素直に受け取れ。","st":"シトリン","sm":"幸運の幸運を温める、シトリンの輝き。"},{"d":228,"n":"Bunda","c":"みずがめ座","ra":21.6292,"dec":-7.85,"m":4.69,"s":"summer","o":"persian","w":"ペルシアの月宿","msg":"みずがめ座、ペルシア語の月宿名。\n暦が違えば、同じ夜空も違って見える。どちらも正しい。","st":"ターコイズ","sm":"ペルシアを護る、青の翼。"},{"d":229,"n":"Nashira","c":"やぎ座","ra":21.6681,"dec":-16.65,"m":3.68,"s":"summer","o":"arabic","w":"幸運の知らせ","msg":"やぎ座、アラビア語で「幸運をもたらす者」。良い知らせは、夜空からも降ってくる。","st":"シトリン","sm":"幸運の知らせに陽光を運ぶ、黄水晶。"},{"d":230,"n":"Azelfafage","c":"はくちょう座","ra":21.7016,"dec":51.18,"m":4.66,"s":"summer","o":"arabic","w":"馬の蹄","msg":"はくちょう座、アラビア語に由来。地を蹴る力は、空を翔ぶ翼と同じだ。","st":"ヘリオドール","sm":"馬蹄に光を宿す、黄金の石。"},{"d":231,"n":"Garnet Star","c":"ケフェウス座","ra":21.7251,"dec":58.77,"m":4.08,"s":"summer","o":"english","w":"深紅の星","msg":"ケフェウス座、ハーシェルが「深いガーネット色」と記述、ピアッツィが命名。\n色そのものが、星の名前になることもある。","st":"ガーネット","sm":"深紅を貫く、深い赤の力。"},{"d":232,"n":"Enif","c":"ペガスス座","ra":21.7364,"dec":9.87,"m":2.39,"s":"summer","o":"arabic","w":"馬の鼻先","msg":"ペガスス座、アラビア語で「鼻」、ペガサスの口元の星。\n馬の鼻は、空気を読む器官。\n誰よりも先に、変化に気づく場所。","st":"ヘリオドール","sm":"馬鼻先に光を宿す、黄金の石。"},{"d":233,"n":"Deneb Algedi","c":"やぎ座","ra":21.7839,"dec":-16.12,"m":2.85,"s":"summer","o":"arabic","w":"山羊の尾","msg":"やぎ座、アラビア語で『山羊の尾』。\n尾は、群れの中で振られる旗。\n尾のひと振りは、言葉より早く、気持ちを伝える。","st":"イエロージャスパー","sm":"尾を支える、大地の黄色。"},{"d":234,"n":"Aldhanab","c":"つる座","ra":21.8986,"dec":-37.35,"m":2.98,"s":"summer","o":"arabic","w":"鶴の尾","msg":"つる座、アラビア語で『尾』、鶴のしっぽに当たる星。\n飛ぶ鳥の尾は、舵の役割。\n美しさは、いちばん端の、尾の先に出る。","st":"ブルートパーズ","sm":"尾を澄ませる、青のトパーズ。"},{"d":235,"n":"Kurhah","c":"ケフェウス座","ra":22.0632,"dec":64.62,"m":4.45,"s":"summer","o":"arabic","w":"額の白い星","msg":"ケフェウス座、アラビア語で「馬の額の白い斑点」。\n額の印は、その馬を遠くからでも見分けさせる。","st":"ホワイトムーンストーン","sm":"額印を月光で清める、白の石。"},{"d":236,"n":"Sadalmelik","c":"みずがめ座","ra":22.0964,"dec":-0.32,"m":2.93,"s":"summer","o":"arabic","w":"王の幸運","msg":"みずがめ座、アラビア語で「王者の幸運」。いちばん上に立つ者の運は、いちばん下まで届く。","st":"クリアクオーツ","sm":"王を映す、透明な石。"},{"d":237,"n":"Alnair","c":"つる座","ra":22.1369,"dec":-46.95,"m":1.77,"s":"summer","o":"arabic","w":"翔ぶ翼","msg":"南の鶴座の翼の先、アラビア語で「明るい者」。飛ぶには、まず重さを捨てる勇気が要る。","st":"スギライト","sm":"執着を解き放つ、紫の石。"},{"d":238,"n":"Biham","c":"ペガスス座","ra":22.1697,"dec":6.18,"m":3.53,"s":"summer","o":"arabic","w":"子らの幸運","msg":"ペガスス座、アラビア語で「子羊・子山羊・子牛の幸運の星」。\n小さな命を見守る星にも、幸運の名が宿る。","st":"イエロージャスパー","sm":"子獣を地に結ぶ、土の黄。"},{"d":239,"n":"Ancha","c":"みずがめ座","ra":22.2806,"dec":-7.77,"m":4.175,"s":"summer","o":"latin","w":"境目の腰","msg":"みずがめ座、ラテン語で「腰」。\n腰は、上半身と下半身の境目。\n腰は、上と下の両方を支える。どちらも、君の一部だ。","st":"ロードナイト","sm":"境目の腰を解きほぐす、優しい桃色。"},{"d":240,"n":"Lang-exster","c":"きょしちょう座","ra":22.3083,"dec":-60.25,"m":2.85,"s":"summer","o":"contemporary","w":"サイチョウとカササギ","msg":"きょしちょう座、マレー語＋オランダ語で二種の鳥の合成名。\n異なる文化が一つの星に名をつける、その出会いを尊べ。","st":"ホワイトオパール","sm":"サイチョウとカササギを彩る、虹色の白。"},{"d":241,"n":"Sadachbia","c":"みずがめ座","ra":22.3608,"dec":-1.38,"m":3.85,"s":"summer","o":"arabic","w":"幸運の天幕","msg":"みずがめ座、アラビア語で「天幕の幸運」。屋根の下にいる時間は、運が育つ時間。","st":"シトリン","sm":"幸運の天幕に陽光を運ぶ、黄水晶。"},{"d":242,"n":"Taika","c":"とかげ座","ra":22.3675,"dec":45.45,"m":3.0,"s":"summer","o":"baltic","w":"平和","msg":"とかげ座、リトアニア語で「平和」。\n平和は、それを願う人がいる限り、星に名を残す。","st":"ローズクオーツ","sm":"平和に愛を宿す、ローズの輝き。"},{"d":243,"n":"Stellio","c":"とかげ座","ra":22.5214,"dec":50.27,"m":3.78,"s":"summer","o":"latin","w":"トカゲ","msg":"とかげ座、ラテン語で「トカゲ」、ヘヴェリウスが付けた別名。\n動かないように見えて、瞳は見ている。","st":"タイガーアイ","sm":"トカゲを貫く、金の眼差し。"},{"d":244,"n":"Homam","c":"ペガスス座","ra":22.6908,"dec":10.82,"m":3.42,"s":"summer","o":"arabic","w":"幸運の星","msg":"ペガスス座、アラビア語で「幸運」。運は、待つよりも、迎えに行くもの。","st":"シトリン","sm":"幸運に陽光を運ぶ、黄水晶。"},{"d":245,"n":"Tiaki","c":"つる座","ra":22.7111,"dec":-46.88,"m":2.12,"s":"summer","o":"polynesian","w":"守る","msg":"つる座、ニュージーランド・マオリ語で「守護する」。守ること、それが愛のいちばんシンプルな形。","st":"ジェード","sm":"守護を結ぶ、緑の翡翠。"},{"d":246,"n":"Matar","c":"ペガスス座","ra":22.7167,"dec":30.22,"m":2.93,"s":"summer","o":"arabic","w":"幸運の雨","msg":"ペガスス座、アラビア語で「降る雨」。望んだ瞬間ではなく、必要な時に降ってくる。","st":"アクアマリン","sm":"降る雨を清める、水の輝き。"},{"d":247,"n":"Sadalbari","c":"ペガスス座","ra":22.8333,"dec":24.6,"m":3.51,"s":"autumn","o":"arabic","w":"鞍の幸運","msg":"ペガスス座、アラビア語で「鞍を背負う幸運な星」。運ぶものを持つ者は、運ぶ場所を持つ者でもある。","st":"ヘリオドール","sm":"鞍幸運を温める、太陽の黄。"},{"d":248,"n":"Shatabhisha","c":"みずがめ座","ra":22.8767,"dec":-7.57,"m":3.75,"s":"autumn","o":"sanskrit","w":"百人の医者","msg":"みずがめ座、サンスクリット語で「百人の医師」、ヴェーダの月宿。\n癒す者は百人いてもいい。\n受ける者は、自分を選べばいい。","st":"エメラルド","sm":"癒しに若さを宿す、エメラルドの輝き。"},{"d":249,"n":"Skat","c":"みずがめ座","ra":22.9108,"dec":-15.82,"m":3.27,"s":"autumn","o":"arabic","w":"水を運ぶ脚","msg":"みずがめ座、アラビア語で「脛」。立つ場所があれば、何度でも立ち上がれる。","st":"イエロージェード","sm":"立つ脚を支える、温かな黄翡翠。"},{"d":250,"n":"Fomalhaut","c":"みなみのうお座","ra":22.9606,"dec":-29.62,"m":1.23,"s":"autumn","o":"arabic","w":"孤独の魚","msg":"周りに大きな星がない、ぽつんと光る一等星。群れずに輝けるのは才能だ。","st":"ムーンストーン","sm":"孤独に月の力を宿す、白の輝き。"},{"d":251,"n":"Alfarasalkamil","c":"アンドロメダ座","ra":23.0319,"dec":42.32,"m":3.64,"s":"autumn","o":"arabic","w":"完全な馬","msg":"アンドロメダ座、アラビア語で「完全な馬」、半身の馬ペガススへの対比。\n半分しか描かれない時代の人にも、全体を想像する力があった。","st":"イエロージャスパー","sm":"馬を支える、大地の黄色。"},{"d":252,"n":"Scheat","c":"ペガスス座","ra":23.0628,"dec":28.07,"m":2.48,"s":"autumn","o":"arabic","w":"馬の脚","msg":"ペガスス座、アラビア語で「脛」。地に立つ脚があるから、空を翔ぶ翼が活きる。","st":"イエロージェード","sm":"立つ脚に滋養を宿す、黄のジェード。"},{"d":253,"n":"Fumalsamakah","c":"うお座","ra":23.0646,"dec":3.82,"m":4.52,"s":"autumn","o":"arabic","w":"魚の口","msg":"うお座、アラビア語で『魚の口』。\n口は、世界を取り込む入り口。\n何を食べるかが、何になるかを決める。","st":"アクアマリン","sm":"魚口を澄ませる、海の青。"},{"d":254,"n":"Markab","c":"ペガスス座","ra":23.0792,"dec":15.2,"m":2.49,"s":"autumn","o":"arabic","w":"鞍","msg":"ペガスス座、アラビア語で「乗り物」、空飛ぶ馬の鞍。上にあるものを支える役には、誇りがある。","st":"ヘリオドール","sm":"鞍に光を宿す、黄金の石。"},{"d":255,"n":"Safina","c":"みずがめ座","ra":23.1572,"dec":-21.17,"m":3.68,"s":"autumn","o":"arabic","w":"古代アラビアの船","msg":"みずがめ座、アラビア語の星宿で「船」、ディフダとフォーマルハウトを結ぶ古代の船。\n二つの星を結べば、その間に船が見える。","st":"ブルーアパタイト","sm":"船を研ぐ、鋭い青の石。"},{"d":256,"n":"Honores","c":"アンドロメダ座","ra":23.2092,"dec":49.4,"m":4.52,"s":"autumn","o":"latin","w":"栄誉","msg":"アンドロメダ座、ラテン語で「栄誉」、1801年Bode命名の追悼の星座。\n栄誉は、生きている間より、後の世に長く残る。","st":"クリアクオーツ","sm":"栄誉を澄ませる、清らかな水晶。"},{"d":257,"n":"Salm","c":"ペガスス座","ra":23.344,"dec":23.73,"m":4.58,"s":"autumn","o":"arabic","w":"まとう革","msg":"ペガスス座、アラビア語で「革・皮」。まとっているものが、その人を守っている。","st":"レッドジャスパー","sm":"皮に根を張る、土の赤。"},{"d":258,"n":"Alkarab","c":"ペガスス座","ra":23.423,"dec":23.4,"m":4.4,"s":"autumn","o":"arabic","w":"桶の縄","msg":"ペガスス座、アラビア語で「水汲み桶の縄」。\n縄は、汲む者と水を繋ぐ。\n見えない繋ぎが、暮らしを支える。","st":"カーネリアン","sm":"縄を支える、生命の赤。"},{"d":259,"n":"Udkadua","c":"アンドロメダ座","ra":23.6261,"dec":46.45,"m":3.86,"s":"autumn","o":"sumerian","w":"嵐を司る者","msg":"アンドロメダ座、シュメール語で「口を開けた嵐の精」、3000年前のバビロニア星座。\n古代の人々が恐れた嵐に、名前を与えて手懐けた。\n名前を呼ぶことは、最初の支配。","st":"ラピスラズリ","sm":"嵐を抱く、夜空の深青。"},{"d":260,"n":"Rasalnaqa","c":"アンドロメダ座","ra":23.6356,"dec":43.27,"m":4.29,"s":"autumn","o":"arabic","w":"雌ラクダの頭","msg":"アンドロメダ座、アラビア語で「雌ラクダの頭」。\nプトレマイオスは「アンドロメダの手」と呼んだ。\n見方が変われば、星の物語も変わる。","st":"スモーキークオーツ","sm":"ラクダに静けさを宿す、煙水晶。"},{"d":261,"n":"Errai","c":"ケフェウス座","ra":23.6556,"dec":77.62,"m":3.21,"s":"autumn","o":"arabic","w":"羊飼い","msg":"ケフェウス座、アラビア語で「羊飼い」。夜の羊飼いは、星を数えて時を知る。","st":"スモーキークオーツ","sm":"羊飼いを包む、煙色の輝き。"},{"d":262,"n":"Kaffalmusalsala","c":"アンドロメダ座","ra":23.6735,"dec":44.33,"m":4.139,"s":"autumn","o":"arabic","w":"鎖の手","msg":"アンドロメダ座、アラビア語で『鎖に繋がれた手』、プトレマイオスの『アンドロメダの手』から。\n鎖は、心までは届かない。","st":"ローズクオーツ","sm":"縛られた手に愛を宿す、ローズの輝き。"},{"d":263,"n":"Hydor","c":"くじら座","ra":0.0623,"dec":-17.33,"m":4.483,"s":"autumn","o":"greek","w":"水","msg":"くじら座、ギリシャ語で「水」、古代の広大な薄い星々の星座名。\n水は、形を持たないから、すべての形になれる。","st":"アクアマリン","sm":"水に静けさを宿す、海色の石。"},{"d":264,"n":"Alpheratz","c":"アンドロメダ座","ra":0.1397,"dec":29.08,"m":2.06,"s":"autumn","o":"arabic","w":"王女の頭","msg":"アンドロメダ座とペガスス座、二つの星座にまたがる稀有な星。\n姫の頭であり、天馬の腰でもある。\n所属を一つに決めなくていい。","st":"ブルーカルセドニー","sm":"穏やかな対話を抱きしめる、優しいブルー。"},{"d":265,"n":"Caph","c":"カシオペヤ座","ra":0.1528,"dec":59.15,"m":2.28,"s":"autumn","o":"arabic","w":"手のひらの星","msg":"カシオペヤのWの右端、アラビア語で「手のひら」。誰かの手のひらの上にある幸運も、君が引き寄せたものだ。","st":"ホワイトカルセドニー","sm":"受け取る力を受け取る、白の石。"},{"d":266,"n":"Algenib","c":"ペガスス座","ra":0.2206,"dec":15.18,"m":2.84,"s":"autumn","o":"arabic","w":"名を旅する星","msg":"ペガスス座、アラビア語で「脇腹」、本来はペルセウス座 α の名前。\n名前は移動する。\nどこに居るかは、時代とともに変わっていい。","st":"ヘマタイト","sm":"脇腹を護る、ヘマタイトの黒。"},{"d":267,"n":"Ankaa","c":"ほうおう座","ra":0.4381,"dec":-42.3,"m":2.38,"s":"autumn","o":"arabic","w":"不死鳥","msg":"ほうおう座、アラビア語で「伝説の鳥」。\n灰から蘇る鳥は、終わりを始まりに変える。","st":"ガーネット","sm":"不死鳥を貫く、深い赤の力。"},{"d":268,"n":"Cexing","c":"カシオペヤ座","ra":0.55,"dec":62.92,"m":4.12,"s":"autumn","o":"chinese","w":"馬の鞭","msg":"カシオペヤ座、中国名で「鞭」、王良星座の隣の御者の道具。\n鞭は、振るうより見せる方が効く。","st":"ヘマタイト","sm":"鞭を地に置く、深黒の石。"},{"d":269,"n":"Fulu","c":"カシオペヤ座","ra":0.6161,"dec":53.88,"m":3.68,"s":"autumn","o":"chinese","w":"影の副官","msg":"カシオペヤ座、中国名で「副官」、紫宮の副道を司る役人。\n主役の影で道を整える者が、組織を支える。","st":"イエロージェード","sm":"副官を支える、温かな黄翡翠。"},{"d":270,"n":"Schedar","c":"カシオペヤ座","ra":0.675,"dec":56.53,"m":2.25,"s":"autumn","o":"arabic","w":"胸に宿る","msg":"王妃カシオペヤの胸。誇りは見せびらかすものじゃない。胸の奥で温め続けたものは、いつか形になって出てくる。","st":"カーネリアン","sm":"内なる誇りを支える、生命の赤。"},{"d":271,"n":"Diphda","c":"くじら座","ra":0.7264,"dec":-17.98,"m":2.05,"s":"autumn","o":"arabic","w":"鯨の尾","msg":"くじら座の尾の星。大きなものほど、ゆっくり動く。焦るな。","st":"イエロージャスパー","sm":"鯨の尾を地に結ぶ、土の黄。"},{"d":272,"n":"Shimu","c":"アンドロメダ座","ra":0.789,"dec":24.27,"m":3.92,"s":"autumn","o":"chinese","w":"天の豚の眼","msg":"アンドロメダ座、中国の最古の星名「天の豚の眼」。\n古代中国の天空に、天の豚が眠っていた。\n動物の見方は、文化で変わる。","st":"タイガーアイ","sm":"天豚眼に勇気を宿す、虎眼石。"},{"d":273,"n":"Achird","c":"カシオペヤ座","ra":0.8181,"dec":57.8,"m":3.46,"s":"autumn","o":"contemporary","w":"近代の名","msg":"カシオペヤ座、20世紀に新たに命名された星。\n今になって名前を持つ星にも、千年の光が宿る。","st":"クリアクオーツ","sm":"新しき名を清浄に保つ、白の結晶。"},{"d":274,"n":"Castula","c":"カシオペヤ座","ra":0.9444,"dec":59.17,"m":4.62,"s":"autumn","o":"latin","w":"女のチュニック","msg":"カシオペヤ座、ラテン語で「婦人服」、Bayer 1603命名。\n服は、その人の姿勢を作る。\n選ぶ服は、選ぶ生き方だ。","st":"ローズクオーツ","sm":"服に愛を宿す、ローズの輝き。"},{"d":275,"n":"Tiansi","c":"カシオペヤ座","ra":0.945,"dec":60.72,"m":2.18,"s":"autumn","o":"chinese","w":"天の四頭立て馬車","msg":"カシオペヤ座、中国名で「天の駟」、2000年以上前の星宿。\n四頭の馬は、揃って同じ方向に進む。\nチームとは、揃うこと。","st":"イエロージャスパー","sm":"馬車を支える、大地の黄色。"},{"d":276,"n":"Kui","c":"アンドロメダ座","ra":0.9534,"dec":23.42,"m":4.403,"s":"autumn","o":"chinese","w":"奎宿","msg":"アンドロメダ座、中国の二十八宿のひとつ「脚」。\n古代中国の時代に、ζ Andが代表星だった。\n時代と共に、代表は変わる。","st":"ヒスイ","sm":"奎宿を保つ、皇の翡翠。"},{"d":277,"n":"Wurren","c":"ほうおう座","ra":1.1397,"dec":-55.23,"m":3.9,"s":"autumn","o":"aboriginal","w":"小さき魚","msg":"ほうおう座、豪州ワダマン族の言葉で「子供」、生命を司るカエル女神の子。\n命の継承者には、必ず守り手がいる。","st":"アクアマリン","sm":"子魚を澄ませる、海の青。"},{"d":278,"n":"Tarandus","c":"ケフェウス座","ra":1.1458,"dec":86.25,"m":4.244,"s":"autumn","o":"latin","w":"トナカイ","msg":"ケフェウス座、ラテン語化された『トナカイ』、近代ヨーロッパで定められた名。\nどこに生まれても、空には自分の場所がある。","st":"ホワイトクリスタル","sm":"トナカイに純度を宿す、白の輝き。"},{"d":279,"n":"Junnanmen","c":"アンドロメダ座","ra":1.1584,"dec":47.23,"m":4.25,"s":"autumn","o":"chinese","w":"南の軍門","msg":"アンドロメダ座、中国名で「南の軍隊の門」。\n門は、出ていく場所であり、戻る場所でもある。","st":"レッドジャスパー","sm":"門を地に結ぶ、力強い赤。"},{"d":280,"n":"Mirach","c":"アンドロメダ座","ra":1.1619,"dec":35.62,"m":2.07,"s":"autumn","o":"arabic","w":"王女の腰","msg":"アンドロメダ姫の腰の星、アラビア語で「帯」。縛られていた腰も、ほどけば、いちばん自由に回る。","st":"ロードナイト","sm":"王女の腰にしなやかさを宿す、桜色の石。"},{"d":281,"n":"Ruchbah","c":"カシオペヤ座","ra":1.4303,"dec":60.23,"m":2.68,"s":"autumn","o":"arabic","w":"王妃の膝","msg":"カシオペヤ座、アラビア語で「膝」。膝をつく時間は、立ち上がる準備の時間。","st":"ロードナイト","sm":"王妃の膝を解きほぐす、優しい桃色。"},{"d":282,"n":"Alpherg","c":"うお座","ra":1.5247,"dec":15.33,"m":3.61,"s":"autumn","o":"arabic","w":"注ぎ口","msg":"うお座、アラビア語で『注ぎ口』。\n器に注がれる水のように、与えるものを持つ者は、いつも満ちている。","st":"アクアマリン","sm":"注ぎ口を清める、水の輝き。"},{"d":283,"n":"Titawin","c":"アンドロメダ座","ra":1.614,"dec":41.38,"m":4.1,"s":"autumn","o":"berber","w":"テトゥアン","msg":"アンドロメダ座、モロッコの世界遺産都市の名。\n異なるものと出会った経験は、いつか君の名前の一部になる。","st":"ターコイズ","sm":"文明の交差を守る、空色の石。"},{"d":284,"n":"Achernar","c":"エリダヌス座","ra":1.6283,"dec":-57.23,"m":0.54,"s":"autumn","o":"arabic","w":"川の終わり","msg":"エリダヌス座、アラビア語で『川の終わり』。\n天に流れる長い川の、いちばん遠くで光る星。\n終わりは、次の流れの始まりだ。","st":"アクアマリン","sm":"流れを流れに乗せる、澄んだ青。"},{"d":285,"n":"Nembus","c":"アンドロメダ座","ra":1.6331,"dec":48.62,"m":3.58,"s":"autumn","o":"latin","w":"雲","msg":"アンドロメダ座、ラテン語で「雲」とBayerが解釈した名、Bayer 1603命名。\n雲は、形を変えながら同じ空にとどまる。","st":"ホワイトムーンストーン","sm":"雲を月光で清める、白の石。"},{"d":286,"n":"Dajiangjunbei","c":"ペルセウス座","ra":1.7277,"dec":50.68,"m":4.06,"s":"autumn","o":"chinese","w":"大将軍北","msg":"ペルセウス座、中国名で『天の大将軍』の北端に位置する星。\n誰よりも後ろに立つ者が、前線を守っている。","st":"ヘマタイト","sm":"将軍を地に置く、深黒の石。"},{"d":287,"n":"Torcular","c":"うお座","ra":1.7566,"dec":9.15,"m":4.27,"s":"autumn","o":"latin","w":"搾り器","msg":"うお座、ラテン語で「ぶどう搾り」。搾れば搾るほど、本質が出る。","st":"レッドガーネット","sm":"搾り器を貫く、深い赤の石。"},{"d":288,"n":"Baten Kaitos","c":"くじら座","ra":1.8575,"dec":-10.33,"m":3.73,"s":"autumn","o":"arabic","w":"鯨の腹","msg":"くじら座、アラビア語で「鯨の腹」。大きく抱える者は、深く沈める者でもある。","st":"ブルートパーズ","sm":"鯨腹を澄ませる、青のトパーズ。"},{"d":289,"n":"Mothallah","c":"さんかく座","ra":1.8844,"dec":29.57,"m":3.41,"s":"autumn","o":"arabic","w":"三角形","msg":"さんかく座、アラビア語で「三角形」、さんかく座そのもの。\n三点が結ばれた瞬間に、形が生まれる。","st":"エメラルド","sm":"三角を育む、深い緑。"},{"d":290,"n":"Mesarthim","c":"おひつじ座","ra":1.8922,"dec":19.28,"m":3.86,"s":"autumn","o":"arabic","w":"二つの召使","msg":"おひつじ座、アラビア語で「召使たち」、二つの星のペア。対で在ることで、初めて見える形がある。","st":"ローズクオーツ","sm":"二つ召使に愛を宿す、ローズの輝き。"},{"d":291,"n":"Segin","c":"カシオペヤ座","ra":1.9064,"dec":63.67,"m":3.35,"s":"autumn","o":"contemporary","w":"カシオペヤの脚","msg":"カシオペヤ座、近代に再命名された名。王妃の脚は、座っていても、踊っている。","st":"カーネリアン","sm":"王妃の足元の奥で燃える、勇気の赤。"},{"d":292,"n":"Sheratan","c":"おひつじ座","ra":1.9106,"dec":20.8,"m":2.66,"s":"autumn","o":"arabic","w":"対の角","msg":"おひつじ座、アラビア語で「二つのしるし」。二本の角は、別々の方を向きながら、同じ頭を守る。","st":"カーネリアン","sm":"対を温め続ける、太陽の赤。"},{"d":293,"n":"Alrescha","c":"うお座","ra":2.0341,"dec":2.75,"m":3.82,"s":"autumn","o":"arabic","w":"紐の結び","msg":"うお座、アラビア語で「結び目」、二匹の魚を結ぶ紐の点。つなぎ目は、関係の中で最も繊細な場所。","st":"ピンクトルマリン","sm":"繋ぎを結ぶ、優しいピンク。"},{"d":294,"n":"Gang","c":"カシオペヤ座","ra":2.0569,"dec":72.42,"m":3.95,"s":"autumn","o":"chinese","w":"天蓋の柄","msg":"カシオペヤ座、中国名で「柄」、華蓋星座の一部。\n本体を支える柄は、目立たないけれど不可欠。","st":"イエロージェード","sm":"柄に滋養を宿す、黄のジェード。"},{"d":295,"n":"Almach","c":"アンドロメダ座","ra":2.0647,"dec":42.32,"m":2.17,"s":"autumn","o":"arabic","w":"金と青の物語","msg":"金色と青の二重星、アンドロメダ姫の足。対照的なものほど、組み合わせると美しい。","st":"ブルートパーズ","sm":"対比を照らす、透き通る青。"},{"d":296,"n":"Hamal","c":"おひつじ座","ra":2.1194,"dec":23.45,"m":2.02,"s":"autumn","o":"arabic","w":"春の角","msg":"秋の空に昇る、来春の予感、おひつじ座の角。やり直しは、いつでも始められる。","st":"レッドカーネリアン","sm":"春の予感を温める、再生の赤。"},{"d":297,"n":"Alaybasan","c":"さんかく座","ra":2.1589,"dec":34.98,"m":3.0,"s":"autumn","o":"arabic","w":"二つの関節","msg":"さんかく座、アラビア語で「二つの骨の関節」、古代アラビアの星宿。\n関節は、曲げられる場所。\n融通の効く場所が、構造を支える。","st":"ロードナイト","sm":"二つの関節に柔らかさを贈る、ロードナイト。"},{"d":298,"n":"Apdu","c":"さんかく座","ra":2.2886,"dec":33.83,"m":4.01,"s":"autumn","o":"egyptian","w":"エジプトの古鳥","msg":"さんかく座、エジプト語で「鳥」、紀元前2千年紀の古代星座。\n21種類の綴り違いを千年超えて受け継いだ名。\n古い言葉ほど、形が揺れる。","st":"ホワイトオパール","sm":"エジプトの古鳥を彩る、虹色の白。"},{"d":299,"n":"Mira","c":"くじら座","ra":2.3224,"dec":-2.97,"m":2.0,"s":"autumn","o":"latin","w":"驚異の星","msg":"くじら座、ラテン語で「驚異」、ヘヴェリウスが「驚異の星の小史」と書いた変光星。\n見るたびに変わる星もある。\n変化は、退屈じゃなく驚きだ。","st":"レッドガーネット","sm":"驚異を貫く、深い赤の石。"},{"d":300,"n":"Huagai","c":"カシオペヤ座","ra":2.4844,"dec":67.4,"m":4.5,"s":"autumn","o":"chinese","w":"天蓋","msg":"カシオペヤ座、中国名で「皇帝の天蓋」、十六星から成る古代星座。\n上に被さるものは、その下にいる者を選ぶ。","st":"ヒスイ","sm":"天蓋を保つ、皇の翡翠。"},{"d":301,"n":"Polaris","c":"こぐま座","ra":2.5297,"dec":89.25,"m":2.0,"s":"autumn","o":"latin","w":"動かぬ星","msg":"天の北極にいる、迷う夜の道しるべ。誰かに「あなたがいたから道がわかった」と言わせる星に。","st":"クリアクオーツ","sm":"方角を澄ませる、清らかな水晶。"},{"d":302,"n":"Kaffaljidhma","c":"くじら座","ra":2.7217,"dec":3.23,"m":3.57,"s":"autumn","o":"arabic","w":"短き手","msg":"くじら座、アラビア語で「短き手」、くじらの頭の星宿。\n失ったものを名にすることで、覚えていられる。","st":"ローズクオーツ","sm":"記憶に愛を宿す、ローズの輝き。"},{"d":303,"n":"Lilii Borea","c":"おひつじ座","ra":2.7985,"dec":29.23,"m":4.514,"s":"autumn","o":"latin","w":"北の百合","msg":"おひつじ座、近代命名でラテン語「北の百合」。古い名前を上書きする勇気もある。","st":"ローズクオーツ","sm":"百合を包み込む、優しいピンク。"},{"d":304,"n":"Bharani","c":"おひつじ座","ra":2.8331,"dec":27.25,"m":3.59,"s":"autumn","o":"sanskrit","w":"運ぶ者","msg":"おひつじ座、サンスクリット語で「運ぶ者」、ヴェーダの第二の月宿。\n運ぶ者は、自分が運んでいるものを知っている。","st":"エメラルド","sm":"運を育む、深い緑。"},{"d":305,"n":"Miram","c":"ペルセウス座","ra":2.8447,"dec":55.88,"m":3.76,"s":"autumn","o":"arabic","w":"誤記された手首","msg":"ペルセウス座、アラビア語の「手首」の誤記の可能性。\n誤記すらも、千年経てば本物の名前になる。","st":"ロードナイト","sm":"誤記された手首を解きほぐす、優しい桃色。"},{"d":306,"n":"Angetenar","c":"エリダヌス座","ra":2.8506,"dec":-21.0,"m":4.78,"s":"autumn","o":"arabic","w":"川の曲がり","msg":"エリダヌス座、アラビア語で「川の蛇行」。\n曲がった川は、まっすぐな川より長く流れる。","st":"アクアマリン","sm":"川を清める、水の輝き。"},{"d":307,"n":"Azha","c":"エリダヌス座","ra":2.9403,"dec":-8.88,"m":3.9,"s":"autumn","o":"arabic","w":"蛇の巣","msg":"エリダヌス座、アラビア語で「孵化場所」。生まれる場所を、大切に守れ。","st":"エメラルド","sm":"蛇巣を育む、深い緑。"},{"d":308,"n":"Acamar","c":"エリダヌス座","ra":2.9708,"dec":-40.3,"m":3.22,"s":"autumn","o":"arabic","w":"古き川の終点","msg":"エリダヌス座、アラビア語で「川の終わり」、本来 θ Eri の名。\n終わりに名を持つ星は、始まりを覚えている。","st":"アクアマリン","sm":"終端を流れに乗せる、澄んだ青。"},{"d":309,"n":"Menkar","c":"くじら座","ra":3.0378,"dec":4.08,"m":2.54,"s":"autumn","o":"arabic","w":"鯨の呼吸","msg":"くじら座、アラビア語で「鼻孔」、本来は λ Cet の名。\n鼻孔は、世界を吸い込む入口。\n呼吸が、その人の輪郭を作る。","st":"ヘリオドール","sm":"鯨呼吸を温める、太陽の黄。"},{"d":310,"n":"Algol","c":"ペルセウス座","ra":3.1361,"dec":40.95,"m":2.11,"s":"autumn","o":"arabic","w":"変身する魔女","msg":"明るさが変わる「悪魔の星」、メドゥーサの首。気分の波を恥じるな、それも君のリズムだ。","st":"ヘマタイト","sm":"変化を地に置く、深黒の石。"},{"d":311,"n":"Misam","c":"ペルセウス座","ra":3.1581,"dec":44.85,"m":3.79,"s":"autumn","o":"arabic","w":"届く手","msg":"ペルセウス座、アラビア語で「手首」。届くかどうかは、手を伸ばしてみるまでわからない。","st":"ロードナイト","sm":"届く手を解きほぐす、優しい桃色。"},{"d":312,"n":"Botein","c":"おひつじ座","ra":3.1938,"dec":19.72,"m":4.349,"s":"autumn","o":"arabic","w":"抱かれる小さき身","msg":"おひつじ座、アラビア語で「小さな腹」。小ささは、抱きしめられる大きさだ。","st":"カーネリアン","sm":"温かみを温め続ける、太陽の赤。"},{"d":313,"n":"Dalim","c":"ろ座","ra":3.2011,"dec":-28.98,"m":3.92,"s":"autumn","o":"arabic","w":"ダチョウ","msg":"ろ座、アラビア語で「ダチョウ」、フォーマルハウトを含む古代アラビアの星宿。\n飛べない鳥は、地で速く走る。\n諦めた一つの能力が、別の能力を磨く。","st":"カーネリアン","sm":"ダチョウに火を灯す、温かな赤の石。"},{"d":314,"n":"Zibal","c":"エリダヌス座","ra":3.2639,"dec":-8.82,"m":4.8,"s":"autumn","o":"arabic","w":"カモシカ","msg":"エリダヌス座、アラビア語に由来。素早く動くものにも、星の場所がある。","st":"タイガーアイ","sm":"カモシカに勇気を宿す、虎眼石。"},{"d":315,"n":"Mirfak","c":"ペルセウス座","ra":3.4053,"dec":49.85,"m":1.81,"s":"autumn","o":"arabic","w":"英雄の肘","msg":"英雄ペルセウスの肘の星。振りかぶる前の、ためる時間を恐れるな。","st":"ヘリオドール","sm":"準備を温める、太陽の黄。"},{"d":316,"n":"Ran","c":"エリダヌス座","ra":3.5486,"dec":-9.45,"m":3.72,"s":"autumn","o":"nordic","w":"北欧の海神","msg":"エリダヌス座、北欧神話の海の女神、波を立て船乗りを網で捕える。\n海の母は、優しさと容赦のなさを併せ持つ。","st":"アクアマリン","sm":"海女神を流れに乗せる、澄んだ青。"},{"d":317,"n":"Sarvvis","c":"ペルセウス座","ra":3.7153,"dec":47.78,"m":3.02,"s":"autumn","o":"sami","w":"トナカイの雄","msg":"ペルセウス座、サーミ族の星座、北スカンジナビアの先住民の伝統。\n極北を生きる獣のように、寒さの中でこそ角は伸びる。","st":"ホワイトムーンストーン","sm":"北極を月光で清める、白の石。"},{"d":318,"n":"Rana","c":"エリダヌス座","ra":3.7206,"dec":-9.75,"m":3.53,"s":"autumn","o":"latin","w":"蛙","msg":"エリダヌス座、ラテン語で「蛙」。小さく地を跳ねる者にも、星の場所がある。","st":"エメラルド","sm":"蛙を清める、深い翠。"},{"d":319,"n":"Atik","c":"ペルセウス座","ra":3.7386,"dec":32.28,"m":3.91,"s":"autumn","o":"arabic","w":"ペルセウスの肩","msg":"ペルセウス座、アラビア語で「肩」。肩の力を抜くことを、覚えていろ。","st":"ブルーレースアゲート","sm":"肩を解きほぐす、優しい青。"},{"d":320,"n":"Electra","c":"おうし座","ra":3.7478,"dec":24.1,"m":3.71,"s":"autumn","o":"greek","w":"琥珀の星","msg":"プレアデスの一星、ギリシャ語で「輝く」。輝きは、磨いた時間の累積。","st":"アンバー","sm":"琥珀を閉じ込める、太古のアンバー。"},{"d":321,"n":"Taygeta","c":"おうし座","ra":3.7535,"dec":24.47,"m":4.3,"s":"autumn","o":"greek","w":"山の女神","msg":"プレアデスの星、ギリシャ神話のニンフ。高みは、登った者にだけ見える景色を見せる。","st":"エメラルド","sm":"高みを清める、深い翠。"},{"d":322,"n":"Maia","c":"おうし座","ra":3.7636,"dec":24.37,"m":3.86,"s":"autumn","o":"greek","w":"五月の女神","msg":"プレアデスの星、ローマの五月の名の由来。芽吹きを止めるな。","st":"エメラルド","sm":"芽吹きを育む、深い緑。"},{"d":323,"n":"Merope","c":"おうし座","ra":3.7721,"dec":23.93,"m":4.18,"s":"autumn","o":"greek","w":"隠された者","msg":"プレアデスで一番暗い星、人間に嫁いだ姉妹。隠れて咲く花にも価値はある。","st":"ローズクオーツ","sm":"隠れて咲く花を包み込む、優しいピンク。"},{"d":324,"n":"Alcyone","c":"おうし座","ra":3.7914,"dec":24.1,"m":2.88,"s":"autumn","o":"greek","w":"プレアデスの長女","msg":"すばるの中心、ギリシャ神話の海の精。姉妹で在りながら、自分の名を持て。","st":"ホワイトオパール","sm":"プレアデスの長女を彩る、虹色の白。"},{"d":325,"n":"Atlas","c":"おうし座","ra":3.8192,"dec":24.05,"m":3.61,"s":"autumn","o":"greek","w":"天を支える者","msg":"プレアデスの父、天空を背負った巨人。重荷は、それを持てる者にだけ来る。","st":"スモーキークオーツ","sm":"重荷を抱きしめる、煙の石。"},{"d":326,"n":"Pleione","c":"おうし座","ra":3.8198,"dec":24.13,"m":4.77,"s":"autumn","o":"greek","w":"プレアデスの母","msg":"プレアデスの母、ニンフ。育てた者は、いつまでもそこにいる。","st":"アクアマリン","sm":"母性を清める、水の輝き。"},{"d":327,"n":"Custos","c":"きりん座","ra":3.8254,"dec":65.52,"m":4.39,"s":"autumn","o":"latin","w":"収穫の番人","msg":"きりん座、ラテン語で「収穫の番人」、Lalandeが付けた星座名。\n見守る者の名は、自分の名より長く残る。","st":"イエロージャスパー","sm":"番人に安定を宿す、黄のジャスパー。"},{"d":328,"n":"Shaowei","c":"きりん座","ra":3.8393,"dec":71.32,"m":4.66,"s":"autumn","o":"chinese","w":"副衛兵","msg":"きりん座、中国名で「第二の衛兵」、紫宮の右壁の六番目の星。\n二番手が中心を支える。","st":"タイガーアイ","sm":"副衛兵を見据える、虎の眼。"},{"d":329,"n":"Áldu","c":"ペルセウス座","ra":3.9642,"dec":40.0,"m":2.91,"s":"autumn","o":"sami","w":"雌トナカイ","msg":"ペルセウス座、サーミ語で「雌のトナカイ」。\n冬も角を残す雌トナカイは、母性と力強さを兼ね備える。","st":"ホワイトムーンストーン","sm":"母獣を月光で清める、白の石。"},{"d":330,"n":"Zaurak","c":"エリダヌス座","ra":3.9669,"dec":-13.5,"m":2.96,"s":"autumn","o":"arabic","w":"小舟","msg":"エリダヌス座、アラビア語で「小舟」、エリダヌス川を下る。川の流れに任せる勇気もある。","st":"アクアマリン","sm":"小舟を清める、水の輝き。"},{"d":331,"n":"Menkib","c":"ペルセウス座","ra":3.9828,"dec":35.78,"m":4.04,"s":"autumn","o":"arabic","w":"プレアデスの肩","msg":"ペルセウス座、アラビア語で「プレアデスの肩」、星団の隣に位置する星。\n隣にあることで、地名になる星がある。","st":"ヘマタイト","sm":"肩を地に置く、深黒の石。"},{"d":332,"n":"Beid","c":"エリダヌス座","ra":4.1978,"dec":-6.83,"m":4.0,"s":"autumn","o":"arabic","w":"卵","msg":"エリダヌス座、アラビア語で「卵たち」、ダチョウの巣の周りの星々。\n卵は、まだ何になるかわからない可能性。","st":"ホワイトクリスタル","sm":"卵に純度を宿す、白の輝き。"},{"d":333,"n":"Rhombus","c":"レチクル座","ra":4.2403,"dec":-62.47,"m":3.33,"s":"autumn","o":"latin","w":"菱形","msg":"レチクル座、ラテン語で「菱形」、Habrechtが1621年に定義した星座。\n四角形より柔らかい菱形は、対角線を持つ。","st":"クリアクオーツ","sm":"菱形を清浄に保つ、白の結晶。"},{"d":334,"n":"Keid","c":"エリダヌス座","ra":4.2545,"dec":-7.65,"m":4.43,"s":"autumn","o":"arabic","w":"卵の殻","msg":"エリダヌス座、アラビア語で「卵の殻」、ダチョウの巣の周りの星宿。\n殻を破る瞬間が、いちばん怖くて、いちばん輝く。","st":"ホワイトクリスタル","sm":"殻に純度を宿す、白の輝き。"},{"d":335,"n":"Prima Hyadum","c":"おうし座","ra":4.3297,"dec":15.62,"m":3.65,"s":"autumn","o":"latin","w":"ヒアデスの先","msg":"おうし座、ラテン語で「ヒアデスの最初の星」。群れの先頭は、誰よりも早く雨に濡れる。","st":"アクアマリン","sm":"雨の星団に静けさを宿す、海色の石。"},{"d":336,"n":"Secunda Hyadum","c":"おうし座","ra":4.3822,"dec":17.53,"m":3.76,"s":"autumn","o":"latin","w":"ヒアデスの二番目","msg":"おうし座、ラテン語で「ヒアデスの二の星」。二番手は、一番を見ながら歩める。","st":"アクアマリン","sm":"二番手を流れに乗せる、澄んだ青。"},{"d":337,"n":"Beemim","c":"エリダヌス座","ra":4.4006,"dec":-34.02,"m":3.96,"s":"autumn","o":"latin","w":"左後ろ脚","msg":"エリダヌス座、ラテン語で『左の後ろ脚』。\n地を蹴る脚があるから、体は前へ運ばれる。","st":"ヘマタイト","sm":"支える者を地に置く、深黒の石。"},{"d":338,"n":"Ain","c":"おうし座","ra":4.4769,"dec":19.17,"m":3.53,"s":"autumn","o":"arabic","w":"雄牛のもう一つの眼","msg":"おうし座、アラビア語で「雄牛の眼」の略、もともとは α Tau の名前。\nアルデバランの隣で、もう一つの眼として輝く。\n二つの眼で世界を立体に見る。","st":"カーネリアン","sm":"眼を支える、生命の赤。"},{"d":339,"n":"Chamukuy","c":"おうし座","ra":4.4775,"dec":15.87,"m":3.39,"s":"autumn","o":"maya","w":"マヤの小鳥","msg":"おうし座、マヤ語で「小鳥」。小さな声にも、神々が耳を傾ける。","st":"ローズクオーツ","sm":"小さな声を包み込む、優しいピンク。"},{"d":340,"n":"Theemin","c":"エリダヌス座","ra":4.5922,"dec":-30.55,"m":3.81,"s":"autumn","o":"arabic","w":"最後尾の星","msg":"エリダヌス座、アラビア語で「最後の」。いちばん後ろを歩く者は、誰も置き去りにしない。","st":"スモーキークオーツ","sm":"最後を抱きしめる、煙の石。"},{"d":341,"n":"Aldebaran","c":"おうし座","ra":4.5986,"dec":16.5,"m":0.99,"s":"autumn","o":"arabic","w":"雄牛の眼","msg":"赤くまっすぐ見据える、おうし座の眼。逸らさないことが、勇気だ。","st":"カーネリアン","sm":"視線に火を灯す、温かな赤の石。"},{"d":342,"n":"Sceptrum","c":"エリダヌス座","ra":4.6361,"dec":-14.3,"m":3.9,"s":"autumn","o":"latin","w":"王笏","msg":"エリダヌス座、ラテン語で「笏」。権威の象徴は、振らないからこそ意味を持つ。","st":"ラピスラズリ","sm":"王笏を覆う、ラピスの夜。"},{"d":343,"n":"Gaja","c":"おうし座","ra":4.7041,"dec":22.95,"m":4.27,"s":"autumn","o":"sanskrit","w":"象","msg":"おうし座、サンスクリット語で「象」、インドネシア・バリの1300年続く星暦から。\n大きな獣は、ゆっくり動く。\n動きが遅いのは、慎重さの証だ。","st":"イエロージャスパー","sm":"象を地に結ぶ、土の黄。"},{"d":344,"n":"Tabit","c":"オリオン座","ra":4.8306,"dec":6.95,"m":3.18,"s":"winter","o":"arabic","w":"耐える者","msg":"オリオン座、アラビア語で「不変なる者・耐える者」。\nオリオンの盾を構成する一星、変わらないことが力。\n動かないでいる強さも、ある。","st":"ヘマタイト","sm":"耐える者を護る、ヘマタイトの黒。"},{"d":345,"n":"Hassaleh","c":"ぎょしゃ座","ra":4.9497,"dec":33.15,"m":2.66,"s":"winter","o":"arabic","w":"かかと","msg":"ぎょしゃ座、アラビア語で「かかと」。地に着く場所が、立ち上がる原点になる。","st":"ヘマタイト","sm":"かかとに芯を宿す、鉄黒の石。"},{"d":346,"n":"Almaaz","c":"ぎょしゃ座","ra":5.0328,"dec":43.82,"m":3.03,"s":"winter","o":"arabic","w":"雄山羊","msg":"ぎょしゃ座、アラビア語で「山羊」、母なるカペラと対をなす雄。\n対を成すために、別々の名がいる。","st":"イエロージャスパー","sm":"雄山羊を地に結ぶ、土の黄。"},{"d":347,"n":"Saclateni","c":"ぎょしゃ座","ra":5.0411,"dec":41.07,"m":3.77,"s":"winter","o":"latin","w":"小山羊","msg":"ぎょしゃ座、アラビア語で「二頭目の子山羊」。二番目の者にも、自分の物語がある。","st":"カーネリアン","sm":"二番手の奥で燃える、勇気の赤。"},{"d":348,"n":"Ping","c":"うさぎ座","ra":5.0908,"dec":-22.37,"m":3.17,"s":"winter","o":"chinese","w":"屏風","msg":"うさぎ座、中国名で「便所の前の屏風」。\n隠す装置にも、夜空に名前がある。\nプライバシーを守る道具を、軽んじるな。","st":"スモーキークオーツ","sm":"屏風を包む、煙色の輝き。"},{"d":349,"n":"Haedus","c":"ぎょしゃ座","ra":5.1083,"dec":41.23,"m":3.17,"s":"winter","o":"latin","w":"御者の子山羊","msg":"ぎょしゃ座、ラテン語で「子山羊」、御者の左手首の二つの星のひとつ。\n親に守られる小さき者にも、空に居場所がある。","st":"イエロージャスパー","sm":"子山羊を地に結ぶ、土の黄。"},{"d":350,"n":"Cursa","c":"エリダヌス座","ra":5.1308,"dec":-5.08,"m":2.79,"s":"winter","o":"arabic","w":"王の玉座","msg":"エリダヌス座、アラビア語で「玉座」。座る場所を持つ者は、立ち上がる時を選べる。","st":"ラピスラズリ","sm":"王玉座に古代を宿す、深い藍。"},{"d":351,"n":"Bade","c":"うさぎ座","ra":5.2153,"dec":-16.2,"m":3.29,"s":"winter","o":"balinese","w":"葬送の塔","msg":"うさぎ座、バリ語で「火葬塔」、太平洋の星座。\n別れを送る塔の名が、星に刻まれた。\n見送る場所を、丁寧に作れ。","st":"スモーキークオーツ","sm":"葬塔を包む、煙色の輝き。"},{"d":352,"n":"Rigel","c":"オリオン座","ra":5.2422,"dec":-8.2,"m":0.28,"s":"winter","o":"arabic","w":"青の覇者","msg":"オリオンの足元で誰よりも青く燃える。派手じゃなくていい。深い色を持て。","st":"カイヤナイト","sm":"青の覇者を貫く、青の刃。"},{"d":353,"n":"Capella","c":"ぎょしゃ座","ra":5.2781,"dec":45.98,"m":0.08,"s":"winter","o":"latin","w":"母なる御者","msg":"二つの太陽が回る冬の星。誰かを支える人にこそ、自分への光を。","st":"シトリン","sm":"母なる御者を温める、シトリンの輝き。"},{"d":354,"n":"Bellatrix","c":"オリオン座","ra":5.4186,"dec":6.33,"m":1.66,"s":"winter","o":"latin","w":"女戦士","msg":"オリオンの肩で青白く輝く。戦う相手は、外じゃなくて昨日の自分。","st":"ブルームーンストーン","sm":"内なる戦士に月の光を宿す、青の石。"},{"d":355,"n":"Elnath","c":"おうし座","ra":5.4381,"dec":28.6,"m":1.68,"s":"winter","o":"arabic","w":"突き上げる角","msg":"雄牛の角の先端。まっすぐ天を指せ。妥協は丸くしてしまう。","st":"ターコイズ","sm":"突き上げる角を守る、空色の石。"},{"d":356,"n":"Nihal","c":"うさぎ座","ra":5.4706,"dec":-20.75,"m":2.84,"s":"winter","o":"arabic","w":"喉を潤すラクダ","msg":"うさぎ座、アラビア語で「水を飲み始めるラクダたち」、四つの星宿の名。\n渇いた者が水を飲む瞬間は、生きている瞬間。","st":"カーネリアン","sm":"潤いを温め続ける、太陽の赤。"},{"d":357,"n":"Mintaka","c":"オリオン座","ra":5.5333,"dec":-0.28,"m":2.23,"s":"winter","o":"arabic","w":"帯の頂","msg":"オリオンの帯の右端。スタートラインに立てているだけで、もう半分終わっている。","st":"ブルーアベンチュリン","sm":"始まりを励ます、青緑の石。"},{"d":358,"n":"Arneb","c":"うさぎ座","ra":5.5453,"dec":-17.82,"m":2.59,"s":"winter","o":"arabic","w":"野兎","msg":"うさぎ座、アラビア語で「野兎」、うさぎ座そのもの。\n夜行性の動物は、暗闇でも目が利く。\n見えない時間を、見るための時間に変える。","st":"ロードナイト","sm":"野兎にしなやかさを宿す、桜色の石。"},{"d":359,"n":"Meissa","c":"オリオン座","ra":5.5856,"dec":9.93,"m":3.53,"s":"winter","o":"arabic","w":"輝く者","msg":"オリオン座、アラビア語で「輝く者」、オリオンの頭。頭にあるものは、すぐ上に天がある。","st":"ブルートパーズ","sm":"頭の上に清らかさを宿す、青の宝石。"},{"d":360,"n":"Hatysa","c":"オリオン座","ra":5.5903,"dec":-5.9,"m":2.78,"s":"winter","o":"arabic","w":"オリオンの剣","msg":"オリオン座、アラビア語に由来する剣の星。剣を持つ者は、抜かない時間を知っている。","st":"アイオライト","sm":"オリオンの剣を導く、アイオライト。"},{"d":361,"n":"Alnilam","c":"オリオン座","ra":5.6033,"dec":-1.2,"m":1.72,"s":"winter","o":"arabic","w":"真珠の帯","msg":"オリオンの帯の中央、アラビア語で「真珠の紐」。中央に立つ調和を信じよ。","st":"ホワイトパール","sm":"真珠の帯に調和を宿す、白の真珠。"},{"d":362,"n":"Tianguan","c":"おうし座","ra":5.6272,"dec":21.13,"m":3.0,"s":"winter","o":"chinese","w":"天の関所","msg":"おうし座、中国名で「天の関所」、黄道上の関所、開閉する。\n通れる時と通れない時を見極めるのも、知恵。","st":"ラピスラズリ","sm":"天関所に古代を宿す、深い藍。"},{"d":363,"n":"Phact","c":"はと座","ra":5.6606,"dec":-34.07,"m":2.66,"s":"winter","o":"arabic","w":"鳩","msg":"はと座、アラビア語で「鳩」。平和を告げる役は、いちばん遠くまで飛べる者が担う。","st":"ホワイトムーンストーン","sm":"平和を月光で清める、白の石。"},{"d":364,"n":"Alnitak","c":"オリオン座","ra":5.6792,"dec":-1.93,"m":1.9,"s":"winter","o":"arabic","w":"帯留めの星","msg":"オリオンの帯の左端。誰かと並ぶことで、初めて見える形がある。","st":"ラブラドライト","sm":"連帯の中で輝きを変える石。"},{"d":365,"n":"Darlugal","c":"うさぎ座","ra":5.7825,"dec":-14.82,"m":3.55,"s":"winter","o":"sumerian","w":"雄鶏","msg":"うさぎ座、シュメール語で「雄鶏」、家畜化された雄鶏。\n夜明けを告げる声を持つ者は、夜の終わりを最初に知る。","st":"カーネリアン","sm":"雄鶏に火を灯す、温かな赤の石。"},{"d":366,"n":"Saiph","c":"オリオン座","ra":5.7958,"dec":-9.67,"m":2.06,"s":"winter","o":"arabic","w":"剣","msg":"オリオンの剣、アラビア語で「剣」。抜かない剣にこそ、本当の威圧がある。","st":"アイオライト","sm":"剣を導く、アイオライト。"}];

const STARS = STARS_BY_DAY.map(e => ({ day: e.d, name: e.n, en: e.n, c: e.c, ra: e.ra, dec: e.dec, mag: e.m, season: e.s, origin: e.o, word: e.w, msg: e.msg, stone: e.st, stoneMsg: e.sm }));

const SEASON_LABEL = { spring: '春', summer: '夏', autumn: '秋', winter: '冬' };
const ORIGIN_LABEL = {"arabic": "アラビア", "latin": "ラテン", "chinese": "中国", "greek": "ギリシャ", "sumerian": "シュメール", "persian": "ペルシャ", "aboriginal": "豪州先住民", "sanskrit": "サンスクリット", "sami": "サーミ", "marshallese": "マーシャル諸島", "balinese": "バリ", "thai": "タイ", "spanish": "スペイン", "english": "英語", "contemporary": "現代", "newc": "NameExoWorlds", "unknown": "古名", "indonesian": "インドネシア", "berber": "北アフリカ", "african": "アフリカ", "egyptian": "古代エジプト", "polynesian": "ポリネシア", "baltic": "バルト", "nordic": "北欧", "maya": "マヤ"};

function getDirectionSub(dec) {
  if (dec > 60) return "日本全国で一年中見える";
  if (dec > 30) return "日本全国で見やすい";
  if (dec > -10) return "日本全国で観測可能";
  if (dec > -30) return "南が開けた場所で見える";
  if (dec > -45) return "本州南部・九州・沖縄で";
  if (dec > -55) return "沖縄・南西諸島で輝く";
  return "南半球から観測する星";
}

function getOriginSub(origin) {
  const map = {"arabic": "アラビアの古天文書から", "latin": "古代ローマの星表から", "chinese": "古代中国の二十八宿から", "greek": "古代ギリシャの神話から", "sumerian": "5000年前のメソポタミアから", "persian": "古代ペルシアの天文書から", "aboriginal": "オーストラリア先住民の伝承", "sanskrit": "古代インド・サンスクリット語", "sami": "北欧サーミ族の伝統", "marshallese": "マーシャル諸島の航海伝統", "balinese": "バリ島の伝統星暦", "thai": "タイの民族星名", "spanish": "スペイン（イベリア半島）", "english": "近代の英語圏天文学", "contemporary": "近代に命名された星", "newc": "21世紀の系外惑星命名", "unknown": "古から伝わる名前", "indonesian": "インドネシアの島々から", "berber": "北アフリカ・ベルベル文化から", "african": "アフリカ先住民の伝統", "egyptian": "古代エジプトから", "polynesian": "ポリネシアの航海伝統", "baltic": "バルト地方の言葉", "nordic": "北欧神話から", "maya": "マヤ文明の言葉"};
  return map[origin] || '';
}

function getDirection(dec) {
  if (dec > 60) return "北の空";
  if (dec > 30) return "北寄りの空";
  if (dec > -10) return "天頂・南の空";
  if (dec > -30) return "南の空";
  if (dec > -45) return "南の低空";
  if (dec > -55) return "南の地平近く";
  return "南半球の空";
}

function dayOfYear(date) {
  // Calendar is built on leap-year basis (366 entries). Always use leap-year month days
  // so May 7 always maps to day 128, regardless of whether the year is leap or not.
  const m = date.getMonth();
  const d = date.getDate();
  const monthDays = [31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
  let total = d;
  for (let i = 0; i < m; i++) total += monthDays[i];
  return total;
}

function findStarForDate(date) {
  let d = dayOfYear(date);
  if (d < 1) d = 1;
  if (d > 366) d = 366;
  return STARS[d - 1];
}

function angularDist(ra1, ra2) {
  let diff = Math.abs(ra1 - ra2);
  return Math.min(diff, 24 - diff);
}

function formatDate(d) {
  return d.getFullYear() + "年 " + (d.getMonth()+1) + "月 " + d.getDate() + "日";
}

function aspectFromRA(s1, s2) {
  const dist = angularDist(s1.ra, s2.ra);
  const angle = dist * 15;
  if (angle < 8)  return { name:'合', en:'Conjunction', score:90, msg:'重なり合う運命。ほぼ同じ位置に瞬く二つの星。' };
  if (angle < 22) return { name:'準合', en:'Semi-Conjunction', score:75, msg:'近くに並んで光る、空気のような関係。' };
  if (angle < 38) return { name:'六分', en:'Sextile', score:85, msg:'軽やかに共鳴する。自然と心地よい距離感。' };
  if (angle < 52) return { name:'準矩', en:'Semi-Square', score:65, msg:'微妙に噛み合わない、けれど刺激的な関係。' };
  if (angle < 68) return { name:'矩', en:'Square', score:70, msg:'ぶつかって磨かれる。衝突を恐れず議論できれば最強。' };
  if (angle < 82) return { name:'準三分', en:'Quincunx', score:73, msg:'視線が交わらない。距離をとった方が長続きする。' };
  if (angle < 98) return { name:'三分', en:'Trine', score:92, msg:'流れの良い調和。努力なしで自然に合う相性。' };
  if (angle < 112) return { name:'準衝', en:'Sesquiquadrate', score:74, msg:'引き合いつつ反発する、不思議な縁。' };
  if (angle < 128) return { name:'五分', en:'Quintile', score:80, msg:'創造的な刺激を与え合う。一緒にいると新しい何かが生まれる。' };
  if (angle < 142) return { name:'準衝', en:'Inconjunct', score:68, msg:'噛み合わない部分を、面白がれるかどうか。' };
  if (angle < 158) return { name:'三半', en:'Biquintile', score:82, msg:'独立した二つの光が、互いを照らし合う関係。' };
  return { name:'衝', en:'Opposition', score:88, msg:'夜空の対極。反発するからこそ強く惹かれる、鏡映しの関係。' };
}

function seasonAxis(s1, s2) {
  if (s1.season === s2.season) {
    return { score:5, msg:'同じ季節の星。同じ夜空に二人で見上げられる。' };
  }
  const opp = { spring:'autumn', autumn:'spring', summer:'winter', winter:'summer' };
  if (opp[s1.season] === s2.season) {
    return { score:0, msg:'反対の季節。半年待って再び会える、すれ違いの星。' };
  }
  return { score:2, msg:'季節は違うが、夜空の隣同士。少しタイミングをずらして響き合う。' };
}

function hemiAxis(s1, s2) {
  const n1 = s1.dec >= 0, n2 = s2.dec >= 0;
  if (n1 && n2)  return { score:3, msg:'ともに北天の星。同じ視線の先に灯る光。' };
  if (!n1 && !n2) return { score:3, msg:'ともに南天の星。同じ南国の夜を共にする。' };
  return { score:0, msg:'北天と南天。地球を半周して届く想い。' };
}

function originAxis(s1, s2) {
  if (s1.origin === s2.origin) {
    return { score:4, msg:'同じ文化に由来する名。語り継がれてきた言葉が同じ。' };
  }
  return { score:2, msg:'異なる文化の出会い。違う言葉で呼ばれてきた光が、ここで重なる。' };
}

function constellationAxis(s1, s2) {
  if (s1.c === s2.c) {
    return { score:5, msg:'同じ星座の中に並ぶ二人。ひとつの物語の中で、隣同士の星。' };
  }
  return { score:0, msg:'違う星座の星。それぞれの場所で、それぞれの物語を持つ。' };
}

// アスペクト（角度関係）から、その関係の「キャラクター」を描く
// ランク付けではなく、すべて等価で個性的な関係として表現
function getCompatCharacter(aspect, sameDay) {
  if (sameDay) return {
    phrase:'同じ夜空を見上げる二人',
    sub:'同じ星に守られた、鏡映しの関係',
    color:'#f3d27a'
  };
  if (aspect === '合') return {
    phrase:'空気のように寄り添う二人',
    sub:'重なり合う運命、似た者同士の安心感',
    color:'#f3d27a'
  };
  if (aspect === '準合') return {
    phrase:'近くで並んで光る二人',
    sub:'静かに歩調を合わせる関係',
    color:'#f3d27a'
  };
  if (aspect === '六分') return {
    phrase:'軽やかに響き合う二人',
    sub:'心地よく共鳴する、自然な距離感',
    color:'#ff9bbe'
  };
  if (aspect === '三分') return {
    phrase:'自然に流れる調和の二人',
    sub:'努力なしで合う、流れの良い関係',
    color:'#ff9bbe'
  };
  if (aspect === '矩') return {
    phrase:'ぶつかって磨き合う二人',
    sub:'刺激と成長、突破口を生む関係',
    color:'#b3a5ff'
  };
  if (aspect === '準矩') return {
    phrase:'微妙な距離感が刺激になる二人',
    sub:'噛み合わなさが、新しい角度を生む',
    color:'#b3a5ff'
  };
  if (aspect === '五分' || aspect === '三半') return {
    phrase:'独立した光が照らし合う二人',
    sub:'創造的な刺激、互いに高め合う関係',
    color:'#b3a5ff'
  };
  if (aspect === '準三分' || aspect === '準衝') return {
    phrase:'独自のリズムを持つ二人',
    sub:'視線が交わらない、それでも続く縁',
    color:'#7ad3e8'
  };
  if (aspect === '衝') return {
    phrase:'対極から惹き合う二人',
    sub:'夜空の反対側、鏡映しの強い縁',
    color:'#7ad3e8'
  };
  return {
    phrase:'個性が出会う二人',
    sub:'お互いを学び合う関係',
    color:'#b3a5ff'
  };
}

function getKabbalah(score) {
  let n = score;
  while (n > 9) {
    n = String(n).split('').reduce((a,b) => a + parseInt(b), 0);
  }
  const meanings = {
    1: { keyword:'始まりの数', desc:'独立と覚悟、新しい一歩を踏み出す力' },
    2: { keyword:'対の数', desc:'調和と協力、二人で在ることの意味' },
    3: { keyword:'創造の数', desc:'表現と楽観、新しいものが生まれる場' },
    4: { keyword:'基盤の数', desc:'安定と勤勉、足元から築き上げる絆' },
    5: { keyword:'変化の数', desc:'自由と冒険、流れに乗ってゆく勇気' },
    6: { keyword:'愛の数', desc:'責任と慈しみ、誰かを大切にする心' },
    7: { keyword:'神秘の数', desc:'内省と探求、見えないものを見る眼差し' },
    8: { keyword:'無限の数', desc:'豊かさと循環、続いてゆく力の流れ' },
    9: { keyword:'完成の数', desc:'知恵と変容、次の段階へと導く光' }
  };
  return { reduced:n, original:score, keyword:meanings[n].keyword, desc:meanings[n].desc };
}

function getPairStone(aspect, sameDay) {
  if (sameDay) return { name:'パール', msg:'同じ日に守られた二人。鏡のように、互いの輝きを映し合う、月光の真珠。' };
  if (aspect === '合') return { name:'ローズクォーツ', msg:'重なり合う運命を温める、優しいピンクの石。似た者同士の安心感を深める。' };
  if (aspect === '準合') return { name:'アマゾナイト', msg:'静かに歩調を合わせる二人を、穏やかに繋ぐ青緑の石。' };
  if (aspect === '六分') return { name:'ペリドット', msg:'軽やかな共鳴を象徴する、若葉色の宝石。自然な距離感を保つ守り。' };
  if (aspect === '三分') return { name:'エメラルド', msg:'流れの良い調和を宿す、深い緑の宝石。努力なしで合う関係を祝う。' };
  if (aspect === '矩') return { name:'ガーネット', msg:'ぶつかって磨き合う関係に、勇気を宿す深紅の石。衝突を成長に変える。' };
  if (aspect === '準矩') return { name:'カーネリアン', msg:'微妙な距離感を、温かい刺激に変える朱の石。' };
  if (aspect === '五分' || aspect === '三半') return { name:'ラブラドライト', msg:'独立した光が互いを照らす、虹色の輝石。創造的な刺激を宿す。' };
  if (aspect === '準三分' || aspect === '準衝') return { name:'ムーンストーン', msg:'独自のリズムを持つ二人を、月の光で優しく繋ぐ石。' };
  if (aspect === '衝') return { name:'サファイア', msg:'対極から惹き合う強い縁を映す、深い青の宝石。鏡映しの関係を守る。' };
  return { name:'クリアクオーツ', msg:'お互いの個性を透明に映し合う、清らかな水晶。' };
}

function calcCompat(s1, s2) {
  if (s1.day === s2.day) {
    return {
      score:99, label:'鏡映し', axes:[],
      msg:'同じ日の同じ星に守られた二人。あまりに似ていて、たまにぶつかる。'
    };
  }
  const a1 = aspectFromRA(s1, s2);
  const a2 = seasonAxis(s1, s2);
  const a3 = hemiAxis(s1, s2);
  const a4 = originAxis(s1, s2);
  const a5 = constellationAxis(s1, s2);
  const score = Math.min(99, a1.score + a2.score + a3.score + a4.score + a5.score);
  return {
    score, label:a1.name,
    axes:[
      { label:'角度', en:a1.en, msg:a1.msg },
      { label:'季節', msg:a2.msg },
      { label:'半球', msg:a3.msg },
      { label:'文化', msg:a4.msg },
      { label:'星座', msg:a5.msg },
    ],
    msg:''
  };
}

let mode = 'single';

function setMode(m) {
  mode = m;
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.mode === m));
  renderInputs();
  document.getElementById('result').classList.remove('show');
  document.getElementById('result').innerHTML = '';
}

function showLoadingState(result) {
  const msgs = ['夜空のどこかで、あなたの星を探しています…','世界中の言葉を辿っています…','千年前の語り部に、聞いています…','あなたの生まれた日の夜空を、開いています…','砂漠の星見人が、名を思い出しています…'];
  const msg = msgs[Math.floor(Math.random() * msgs.length)];
  result.innerHTML = '<div class="loading-state"><div class="loading-pulse">✦</div><div class="loading-text">' + msg + '</div></div>';
  result.classList.add('show');
}

function resetResult() {
  const result = document.getElementById('result');
  const intro = document.getElementById('intro-card');
  const home = document.getElementById('home');
  if (home) home.classList.remove('hidden');
  if (intro) intro.classList.remove('hidden');
  result.classList.remove('show', 'spring', 'summer', 'autumn', 'winter');
  setTimeout(() => { result.innerHTML = ''; }, 400);
  const b1 = document.getElementById('bday1');
  const b2 = document.getElementById('bday2');
  if (b1) b1.value = '';
  if (b2) b2.value = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
  if (b1) setTimeout(() => b1.focus(), 600);
}

function renderInputs() {
  const inputs = document.getElementById('inputs');
  if (mode === 'single') {
    inputs.innerHTML = '<div class="input-block"><div class="input-label">あなたの誕生日</div><input type="date" id="bday1" /></div>';
  } else {
    inputs.innerHTML =
      '<div class="input-block"><div class="input-label">あなた</div><input type="date" id="bday1" /></div>' +
      '<div class="input-block"><div class="input-label">相手</div><input type="date" id="bday2" /></div>';
  }
}

function reveal() {
  const result = document.getElementById('result');
  const intro = document.getElementById('intro-card');
  const home = document.getElementById('home');
  // 結果が既に表示中なら、もう一度押すと「戻る」動作
  if (result.classList.contains('show')) {
    resetResult();
    return;
  }
  const v1 = document.getElementById('bday1').value;
  if (!v1) { alert('誕生日を選んでください'); return; }
  if (intro) intro.classList.add('hidden');
  if (home) home.classList.add('hidden');
  window.scrollTo({ top: 0, behavior: 'instant' });
  result.classList.remove('show', 'spring', 'summer', 'autumn', 'winter');

  if (mode === 'single') {
    const d = new Date(v1);
    const s = findStarForDate(d);
    const dir = getDirection(s.dec);
    const originLabel = ORIGIN_LABEL[s.origin] || s.origin;
    showLoadingState(result);
    setTimeout(() => {
      result.classList.add(s.season);
      result.innerHTML =
        '<button class="go go-top result-top-btn" onclick="resetResult()">星 を 呼 び 出 す</button>' +
        '<div class="symbol">✦</div>' +
        '<div class="center"><span class="season-tag ' + s.season + '">' + SEASON_LABEL[s.season] + 'の星</span></div>' +
        '<div class="result-intro-main center">あなたの星 ──</div>' + '<div class="result-intro-sub center">千年前から、あなたを待っていた</div>' +
        '<div class="date-display center">' + formatDate(d) + '</div>' +
        '<div class="micro-label center">星の名</div>' +
        '<div class="star-name center">' + s.name + '</div>' +
        '<div class="micro-label center">星座</div>' +
        '<div class="const center">' + s.c + '</div>' +
        '<div class="micro-label center">星言葉</div>' +
        '<div class="word center">「' + s.word + '」</div>' +
        '<div class="msg">' + s.msg + '</div>' +
        '<div class="divider-line"></div>' +
        '<div class="observe-section">' +
          '<div class="observe-item">' +
            '<div class="observe-label">方角</div>' +
            '<div class="observe-value">' + dir + '</div>' +
            '<div class="observe-sub">' + getDirectionSub(s.dec) + '</div>' +
          '</div>' +
          '<div class="observe-item">' +
            '<div class="observe-label">由来</div>' +
            '<div class="observe-value">' + originLabel + '</div>' +
            '<div class="observe-sub">' + getOriginSub(s.origin) + '</div>' +
          '</div>' +
        '</div>' +
        '<div class="divider-line"></div>' +
        '<div class="stone-section center">' +
          '<div class="stone-label">お守り石</div>' +
          '<div class="stone-name">◇ ' + s.stone + '</div>' +
          '<div class="stone-msg">' + s.stoneMsg + '</div>' +
        '</div>' +
        '<div class="action-row">' +
          '<button class="share-btn" onclick="shareS(&apos;' + s.name + '&apos;, &apos;' + s.word + '&apos;, &apos;' + s.stone + '&apos;)">この星をシェア</button>' +
        '</div>';
      setTimeout(() => result.classList.add('show'), 50);
    }, 1400);
  } else {
    const v2 = document.getElementById('bday2').value;
    if (!v2) { alert('相手の誕生日も選んでください'); return; }
    const d1 = new Date(v1);
    const d2 = new Date(v2);
    const s1 = findStarForDate(d1);
    const s2 = findStarForDate(d2);
    const compat = calcCompat(s1, s2);
    showLoadingState(result);
    setTimeout(() => {
      let axesHtml = '';
      if (compat.axes.length > 0) {
        axesHtml = '<div class="axes-section">';
        compat.axes.forEach(ax => {
          axesHtml += '<div class="axis-row"><span class="axis-label">' + ax.label + '</span><span class="axis-msg">' + ax.msg + '</span></div>';
        });
        axesHtml += '</div>';
      }
      result.innerHTML =
        '<button class="go go-top result-top-btn" onclick="resetResult()">星 を 呼 び 出 す</button>' +
        '<div class="symbol">✦  ✦</div>' +
        '<div class="compat-row">' +
          '<div class="compat-mini">' +
            '<div class="date-display">' + formatDate(d1) + '</div>' +
            '<div class="star-name">' + s1.name + '</div>' +
            '<div class="const">' + s1.c + '</div>' +
            '<div class="word">「' + s1.word + '」</div>' +
          '</div>' +
          '<div class="compat-link">⇆</div>' +
          '<div class="compat-mini">' +
            '<div class="date-display">' + formatDate(d2) + '</div>' +
            '<div class="star-name">' + s2.name + '</div>' +
            '<div class="const">' + s2.c + '</div>' +
            '<div class="word">「' + s2.word + '」</div>' +
          '</div>' +
        '</div>' +
        (function(){
          const ch = getCompatCharacter(compat.label, compat.label === '鏡映し');
          return '<div class="compat-character" style="border-color:' + ch.color + '40">' +
            '<div class="compat-phrase" style="color:' + ch.color + '">' + ch.phrase + '</div>' +
            '<div class="compat-sub">' + ch.sub + '</div>' +
            (function(){
              const k = getKabbalah(compat.score);
              return '<div class="compat-score-line">' +
                '<span class="compat-score-label">ラッキーナンバー</span>' +
                '<span class="compat-score-num" style="color:' + ch.color + '">' + k.reduced + '</span>' +
              '</div>' +
              '<div class="compat-kabbalah">' +
                '<span class="compat-kabbalah-keyword" style="color:' + ch.color + '">〈' + k.keyword + '〉</span>' +
              '</div>';
            })() +
            (compat.label !== '鏡映し' ? '<div class="compat-aspect-line">占星術アスペクト：<span class="compat-aspect-name">' + compat.label + '</span></div>' : '') +
          '</div>';
        })() +
        (compat.msg ? '<div class="compat-msg">' + compat.msg + '</div>' : '') +
        axesHtml +
        '<div class="divider-line"></div>' +
        (function(){
          const pair = getPairStone(compat.label, compat.label === '鏡映し');
          return '<div class="stone-section center">' +
            '<div class="stone-label">二人のお守り石</div>' +
            '<div class="stone-name">◇ ' + pair.name + ' ◇</div>' +
            '<div class="stone-msg">' + pair.msg + '</div>' +
          '</div>';
        })() +
        '';
      setTimeout(() => result.classList.add('show'), 50);
    }, 1400);
  }
}

function shareS(name, word, stone) {
  const s = STARS.find(x => x.name === name);
  let quote = word;
  if (s && s.msg) {
    const sentences = s.msg.replace(/\n/g, '').split('。').filter(t => t.trim().length > 0);
    if (sentences.length > 0) quote = sentences[sentences.length - 1].trim();
  }
  const text = '「' + quote + '」\n── 私の星、' + name + '（' + word + '）\n\nあなたの夜空の言葉は？\nhttps://yourstar.jp #365日の星';
  window.open("https://twitter.com/intent/tweet?text=" + encodeURIComponent(text), "_blank");
}

renderInputs();
</script>

</body>
</html>
